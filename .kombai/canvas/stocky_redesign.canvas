      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Space+Mono:wght@400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --deep-teal: #003B46;\n    --dark-teal: #07575B;\n    --light-teal: #66A5AD;\n    --stark-white: #FFFFFF;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--stark-white);\n    color: var(--deep-teal);\n    overflow-x: hidden;\n  }\n\n  .font-mono {\n    font-family: 'Space Mono', monospace;\n  }\n\n  /* Custom Animations */\n  @keyframes ticker {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .animate-ticker {\n    display: flex;\n    width: fit-content;\n    animation: ticker 30s linear infinite;\n  }\n\n  .diagonal-split-left {\n    clip-path: polygon(0 0, 100% 0, 0 100%);\n  }\n\n  .diagonal-split-right {\n    clip-path: polygon(100% 0, 100% 100%, 0 100%);\n  }\n\n  .grid-pattern {\n    background-image: radial-gradient(var(--light-teal) 0.5px, transparent 0.5px);\n    background-size: 20px 20px;\n    opacity: 0.15;\n  }\n\n  .outlined-text {\n    -webkit-text-stroke: 1px var(--light-teal);\n    color: transparent;\n  }\n\n  .module-card {\n    transition: background-color 0ms, color 0ms;\n  }\n\n  .module-card:hover {\n    background-color: var(--dark-teal);\n    color: var(--stark-white);\n  }\n</style>\n\n\n<nav class=\"fixed top-0 left-0 w-full z-50 px-10 py-6 mix-blend-difference flex justify-between items-center text-white\" data-kid=\"1\">\n  <div class=\"font-mono text-xl font-bold tracking-tighter\" data-kid=\"2\">STOCKY // POS</div>\n  <div class=\"flex gap-12 font-mono text-xs uppercase tracking-widest\" data-kid=\"3\">\n    <a href=\"#process\" class=\"hover:text-[var(--light-teal)]\" data-kid=\"4\">Process</a>\n    <a href=\"#modules\" class=\"hover:text-[var(--light-teal)]\" data-kid=\"5\">Modules</a>\n    <a href=\"#download\" class=\"hover:text-[var(--light-teal)]\" data-kid=\"6\">Downloads</a>\n  </div>\n</nav>\n\n\n<section class=\"relative h-screen w-full overflow-hidden\" data-kid=\"7\">\n  \n  <div class=\"absolute inset-0 bg-[var(--deep-teal)] diagonal-split-left z-10 flex flex-col justify-center px-20\" data-kid=\"8\">\n    <div class=\"max-w-2xl text-white\" data-kid=\"9\">\n      <div class=\"font-mono text-xs uppercase tracking-[0.4em] mb-6 text-[var(--light-teal)]\" data-kid=\"10\">System v1.0 // Ready</div>\n      <h1 class=\"text-7xl font-bold leading-tight mb-8\" data-kid=\"11\">\n        PRECISION <br data-kid=\"12\"> RESTAURANT <br data-kid=\"13\"> CONTROL.\n      </h1>\n      <p class=\"text-xl text-[var(--light-teal)] font-light max-w-lg mb-10\" data-kid=\"14\">\n        StockyPOS: The high-speed interface for restaurants, cafes, and bars. Engineered for accuracy, built for scale.\n      </p>\n    </div>\n  </div>\n\n  \n  <div class=\"absolute inset-0 diagonal-split-right z-0\" data-kid=\"15\">\n    <video src=\"https://videos.pexels.com/video-files/6602061/6602061-sd_960_540_30fps.mp4\" poster=\"https://images.pexels.com/videos/6602061/pexels-photo-6602061.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover grayscale contrast-125\" data-kid=\"16\"></video>\n    <div class=\"absolute inset-0 bg-[var(--deep-teal)]/20\" data-kid=\"17\"></div>\n  </div>\n\n  \n  <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20\" data-kid=\"18\">\n    <button class=\"bg-[var(--light-teal)] text-[var(--deep-teal)] px-12 py-5 font-mono font-bold text-sm tracking-widest uppercase hover:bg-white transition-all transform hover:scale-105 active:scale-95\" data-kid=\"19\">\n      Deploy System <i class=\"ti ti-arrow-up-right ml-2\" data-kid=\"20\"></i>\n    </button>\n  </div>\n</section>\n\n\n<div class=\"border-y border-[var(--deep-teal)]/10 py-4 overflow-hidden bg-white\" data-kid=\"21\">\n  <div class=\"animate-ticker\" data-kid=\"22\">\n    <div class=\"flex items-center gap-12 px-6\" data-kid=\"23\">\n      <span class=\"font-mono text-xs font-bold whitespace-nowrap\" data-kid=\"24\"><img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/skoll/diamonds.svg\" class=\"inline w-3 h-3 mr-4\" style=\"filter: invert(18%) sepia(31%) saturate(1542%) hue-rotate(149deg) brightness(91%) contrast(101%);\" data-kid=\"25\"> ALWAYS ACTIVE // 99.9% UPTIME</span>\n      <span class=\"font-mono text-xs font-bold whitespace-nowrap\" data-kid=\"26\"><img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/skoll/diamonds.svg\" class=\"inline w-3 h-3 mr-4\" style=\"filter: invert(18%) sepia(31%) saturate(1542%) hue-rotate(149deg) brightness(91%) contrast(101%);\" data-kid=\"27\"> EXPRESS CHECKOUT // < 2s</span>\n      <span class=\"font-mono text-xs font-bold whitespace-nowrap\" data-kid=\"28\"><img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/skoll/diamonds.svg\" class=\"inline w-3 h-3 mr-4\" style=\"filter: invert(18%) sepia(31%) saturate(1542%) hue-rotate(149deg) brightness(91%) contrast(101%);\" data-kid=\"29\"> SECURE PROTOCOL // AES-256</span>\n      <span class=\"font-mono text-xs font-bold whitespace-nowrap\" data-kid=\"30\"><img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/skoll/diamonds.svg\" class=\"inline w-3 h-3 mr-4\" style=\"filter: invert(18%) sepia(31%) saturate(1542%) hue-rotate(149deg) brightness(91%) contrast(101%);\" data-kid=\"31\"> REAL-TIME SYNC // CLOUD NATIVE</span>\n    </div>\n    \n    <div class=\"flex items-center gap-12 px-6\" data-kid=\"32\">\n      <span class=\"font-mono text-xs font-bold whitespace-nowrap\" data-kid=\"33\"><img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/skoll/diamonds.svg\" class=\"inline w-3 h-3 mr-4\" style=\"filter: invert(18%) sepia(31%) saturate(1542%) hue-rotate(149deg) brightness(91%) contrast(101%);\" data-kid=\"34\"> ALWAYS ACTIVE // 99.9% UPTIME</span>\n      <span class=\"font-mono text-xs font-bold whitespace-nowrap\" data-kid=\"35\"><img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/skoll/diamonds.svg\" class=\"inline w-3 h-3 mr-4\" style=\"filter: invert(18%) sepia(31%) saturate(1542%) hue-rotate(149deg) brightness(91%) contrast(101%);\" data-kid=\"36\"> EXPRESS CHECKOUT // < 2s</span>\n      <span class=\"font-mono text-xs font-bold whitespace-nowrap\" data-kid=\"37\"><img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/skoll/diamonds.svg\" class=\"inline w-3 h-3 mr-4\" style=\"filter: invert(18%) sepia(31%) saturate(1542%) hue-rotate(149deg) brightness(91%) contrast(101%);\" data-kid=\"38\"> SECURE PROTOCOL // AES-256</span>\n      <span class=\"font-mono text-xs font-bold whitespace-nowrap\" data-kid=\"39\"><img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/skoll/diamonds.svg\" class=\"inline w-3 h-3 mr-4\" style=\"filter: invert(18%) sepia(31%) saturate(1542%) hue-rotate(149deg) brightness(91%) contrast(101%);\" data-kid=\"40\"> REAL-TIME SYNC // CLOUD NATIVE</span>\n    </div>\n  </div>\n</div>\n\n\n<section id=\"process\" class=\"py-32 px-20 bg-white\" data-kid=\"41\">\n  <div class=\"mb-20\" data-kid=\"42\">\n    <div class=\"font-mono text-xs uppercase tracking-[0.4em] mb-4 text-[var(--light-teal)]\" data-kid=\"43\">Architecture // 02</div>\n    <h2 class=\"text-5xl font-bold\" data-kid=\"44\">OPERATIONAL FLOW.</h2>\n  </div>\n\n  <div class=\"grid grid-cols-3 border border-[var(--deep-teal)]/20\" data-kid=\"45\">\n    \n    <div class=\"p-16 border-r border-[var(--deep-teal)]/20 flex flex-col min-h-[500px]\" data-kid=\"46\">\n      <div class=\"outlined-text font-mono text-9xl font-bold mb-auto\" data-kid=\"47\">01</div>\n      <div data-kid=\"48\">\n        <h3 class=\"font-mono text-xl font-bold mb-4 uppercase tracking-tighter\" data-kid=\"49\">Inventory Injection</h3>\n        <p class=\"text-[var(--dark-teal)] leading-relaxed\" data-kid=\"50\">\n          Bulk import products, modifiers, and pricing matrices via our technical API or secure dashboard.\n        </p>\n      </div>\n    </div>\n    \n    <div class=\"p-16 border-r border-[var(--deep-teal)]/20 flex flex-col min-h-[500px]\" data-kid=\"51\">\n      <div class=\"outlined-text font-mono text-9xl font-bold mb-auto\" data-kid=\"52\">02</div>\n      <div data-kid=\"53\">\n        <h3 class=\"font-mono text-xl font-bold mb-4 uppercase tracking-tighter\" data-kid=\"54\">Transaction Engine</h3>\n        <p class=\"text-[var(--dark-teal)] leading-relaxed\" data-kid=\"55\">\n          High-frequency sales processing with sub-second latency. Manage tables, bars, and take-out in one unified core.\n        </p>\n      </div>\n    </div>\n    \n    <div class=\"p-16 flex flex-col min-h-[500px]\" data-kid=\"56\">\n      <div class=\"outlined-text font-mono text-9xl font-bold mb-auto\" data-kid=\"57\">03</div>\n      <div data-kid=\"58\">\n        <h3 class=\"font-mono text-xl font-bold mb-4 uppercase tracking-tighter\" data-kid=\"59\">Analytics Extract</h3>\n        <p class=\"text-[var(--dark-teal)] leading-relaxed\" data-kid=\"60\">\n          Generate high-fidelity reports. Audit employee performance and export fiscal data with surgical precision.\n        </p>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"modules\" class=\"bg-[var(--deep-teal)] py-32\" data-kid=\"61\">\n  <div class=\"px-20 mb-20 text-white\" data-kid=\"62\">\n    <div class=\"font-mono text-xs uppercase tracking-[0.4em] mb-4 text-[var(--light-teal)]\" data-kid=\"63\">Modules // 03</div>\n    <h2 class=\"text-5xl font-bold\" data-kid=\"64\">CORE CAPABILITIES.</h2>\n  </div>\n\n  <div class=\"grid grid-cols-3 border-t border-l border-white/10\" data-kid=\"65\">\n    \n    <div class=\"module-card p-12 border-r border-b border-white/10 min-h-[300px] flex flex-col text-white cursor-pointer group\" data-kid=\"66\">\n      <div class=\"font-mono text-[10px] text-[var(--light-teal)] mb-6\" data-kid=\"67\">[MOD-01]</div>\n      <div class=\"mb-auto\" data-kid=\"68\">\n        <i class=\"ti ti-zap text-3xl mb-4 block group-hover:text-white text-[var(--light-teal)]\" data-kid=\"69\"></i>\n        <h4 class=\"font-mono text-lg font-bold uppercase mb-2\" data-kid=\"70\">Cobro Rápido</h4>\n        <p class=\"text-sm text-white/60 group-hover:text-white/80\" data-kid=\"71\">Zero-lag interface for peak-hour performance.</p>\n      </div>\n    </div>\n    \n    <div class=\"module-card p-12 border-r border-b border-white/10 min-h-[300px] flex flex-col text-white cursor-pointer group\" data-kid=\"72\">\n      <div class=\"font-mono text-[10px] text-[var(--light-teal)] mb-6\" data-kid=\"73\">[MOD-02]</div>\n      <div class=\"mb-auto\" data-kid=\"74\">\n        <i class=\"ti ti-file-text text-3xl mb-4 block group-hover:text-white text-[var(--light-teal)]\" data-kid=\"75\"></i>\n        <h4 class=\"font-mono text-lg font-bold uppercase mb-2\" data-kid=\"76\">Facturación Simple</h4>\n        <p class=\"text-sm text-white/60 group-hover:text-white/80\" data-kid=\"77\">Fiscal compliance automated. Print or email instantly.</p>\n      </div>\n    </div>\n    \n    <div class=\"module-card p-12 border-r border-b border-white/10 min-h-[300px] flex flex-col text-white cursor-pointer group\" data-kid=\"78\">\n      <div class=\"font-mono text-[10px] text-[var(--light-teal)] mb-6\" data-kid=\"79\">[MOD-03]</div>\n      <div class=\"mb-auto\" data-kid=\"80\">\n        <i class=\"ti ti-pie-chart text-3xl mb-4 block group-hover:text-white text-[var(--light-teal)]\" data-kid=\"81\"></i>\n        <h4 class=\"font-mono text-lg font-bold uppercase mb-2\" data-kid=\"82\">Reportes Claros</h4>\n        <p class=\"text-sm text-white/60 group-hover:text-white/80\" data-kid=\"83\">Deep dive into data with intuitive visual matrices.</p>\n      </div>\n    </div>\n    \n    <div class=\"module-card p-12 border-r border-b border-white/10 min-h-[300px] flex flex-col text-white cursor-pointer group\" data-kid=\"84\">\n      <div class=\"font-mono text-[10px] text-[var(--light-teal)] mb-6\" data-kid=\"85\">[MOD-04]</div>\n      <div class=\"mb-auto\" data-kid=\"86\">\n        <i class=\"ti ti-user-cog text-3xl mb-4 block group-hover:text-white text-[var(--light-teal)]\" data-kid=\"87\"></i>\n        <h4 class=\"font-mono text-lg font-bold uppercase mb-2\" data-kid=\"88\">Control Empleado</h4>\n        <p class=\"text-sm text-white/60 group-hover:text-white/80\" data-kid=\"89\">Role-based access control and performance auditing.</p>\n      </div>\n    </div>\n    \n    <div class=\"module-card p-12 border-r border-b border-white/10 min-h-[300px] flex flex-col text-white cursor-pointer group\" data-kid=\"90\">\n      <div class=\"font-mono text-[10px] text-[var(--light-teal)] mb-6\" data-kid=\"91\">[MOD-05]</div>\n      <div class=\"mb-auto\" data-kid=\"92\">\n        <i class=\"ti ti-lock text-3xl mb-4 block group-hover:text-white text-[var(--light-teal)]\" data-kid=\"93\"></i>\n        <h4 class=\"font-mono text-lg font-bold uppercase mb-2\" data-kid=\"94\">Info Segura</h4>\n        <p class=\"text-sm text-white/60 group-hover:text-white/80\" data-kid=\"95\">End-to-end encryption for all sensitive business logic.</p>\n      </div>\n    </div>\n    \n    <div class=\"module-card p-12 border-r border-b border-white/10 min-h-[300px] flex flex-col text-white cursor-pointer group\" data-kid=\"96\">\n      <div class=\"font-mono text-[10px] text-[var(--light-teal)] mb-6\" data-kid=\"97\">[MOD-06]</div>\n      <div class=\"mb-auto\" data-kid=\"98\">\n        <i class=\"ti ti-power text-3xl mb-4 block group-hover:text-white text-[var(--light-teal)]\" data-kid=\"99\"></i>\n        <h4 class=\"font-mono text-lg font-bold uppercase mb-2\" data-kid=\"100\">Cierre Fácil</h4>\n        <p class=\"text-sm text-white/60 group-hover:text-white/80\" data-kid=\"101\">Automated daily reconciliation and system backup.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"relative py-64 bg-white overflow-hidden flex justify-center items-center\" data-kid=\"102\">\n  <div class=\"absolute inset-0 grid-pattern\" data-kid=\"103\"></div>\n  \n  <div class=\"relative z-10 text-center\" data-kid=\"104\">\n    <div class=\"w-[500px] h-[500px] bg-[var(--deep-teal)] flex flex-col justify-center items-center p-20 shadow-2xl\" data-kid=\"105\">\n      <div class=\"font-mono text-[10px] text-[var(--light-teal)] mb-8 uppercase tracking-[0.5em]\" data-kid=\"106\">System Status: Ready</div>\n      <h2 class=\"text-4xl font-bold text-white mb-10 leading-tight\" data-kid=\"107\">INITIALIZE <br data-kid=\"108\"> GROWTH.</h2>\n      <button class=\"w-full border border-[var(--light-teal)] text-[var(--light-teal)] py-4 font-mono text-xs uppercase tracking-widest hover:bg-[var(--light-teal)] hover:text-[var(--deep-teal)] transition-colors flex items-center justify-center gap-2 group\" data-kid=\"109\">\n        Create Account <i class=\"ti ti-arrow-up-right group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform\" data-kid=\"110\"></i>\n      </button>\n      <div class=\"mt-8 font-mono text-[8px] text-white/30\" data-kid=\"111\">STOCKY // V1.0.0-STABLE</div>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"bg-white border-t border-[var(--deep-teal)]/10 px-20 py-10\" data-kid=\"112\">\n  <div class=\"flex justify-between items-center font-mono text-[10px] uppercase tracking-widest text-[var(--dark-teal)]\" data-kid=\"113\">\n    <div data-kid=\"114\">© 2026 Stocky POS // All rights reserved</div>\n    <div class=\"flex gap-10\" data-kid=\"115\">\n      <a href=\"#\" class=\"hover:text-[var(--light-teal)]\" data-kid=\"116\">Terms</a>\n      <a href=\"#\" class=\"hover:text-[var(--light-teal)]\" data-kid=\"117\">Privacy</a>\n      <a href=\"#\" class=\"hover:text-[var(--light-teal)]\" data-kid=\"118\">Github</a>\n    </div>\n  </div>\n</footer>\n\n<script type=\"module\" data-kid=\"119\">\n  import { animate, scroll, inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  // Section Entrance Animations\n  inView(\"section\", ({ target }) => {\n    animate(\n      target,\n      { opacity: [0, 1], y: [50, 0] },\n      { duration: 0.8, easing: \"ease-out\" }\n    )\n  })\n\n  // Blueprint Grid Animation\n  inView(\"#process div\", ({ target }) => {\n    animate(\n      target,\n      { opacity: [0, 1], scale: [0.95, 1] },\n      { duration: 0.5, delay: 0.2 }\n    )\n  })\n\n  // Module Grid Snap Hover is CSS handled (transition 0ms) but we could add a subtle sound or tiny scale\n  document.querySelectorAll('.module-card').forEach(card => {\n    card.addEventListener('mouseenter', () => {\n      animate(card, { scale: 1.02 }, { duration: 0.1 });\n    });\n    card.addEventListener('mouseleave', () => {\n      animate(card, { scale: 1 }, { duration: 0.1 });\n    });\n  });\n</script>",

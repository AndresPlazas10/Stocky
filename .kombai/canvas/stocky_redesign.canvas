      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@500&display=swap');\n\n  :root {\n    --color-bg: #E8F4F6;\n    --color-card: #FFFFFF;\n    --color-primary: #003B46;\n    --color-secondary: #07575B;\n    --color-accent: #66A5AD;\n    --font-sans: 'Inter', sans-serif;\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    background-color: var(--color-bg);\n    color: var(--color-primary);\n    font-family: var(--font-sans);\n    margin: 0;\n    overflow-x: clip; /* Prevent sticky break */\n  }\n\n  .bento-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    grid-auto-rows: 240px;\n    gap: 1.5rem;\n  }\n\n  .card-shadow {\n    box-shadow: 12px 12px 0px rgba(0, 59, 70, 0.08);\n  }\n\n  .card-shadow-sm {\n    box-shadow: 6px 6px 0px rgba(0, 59, 70, 0.04);\n  }\n\n  .inset-strip {\n    box-shadow: inset 0 4px 12px rgba(0, 0, 0, 0.08);\n  }\n\n  .ticket-edge {\n    filter: drop-shadow(0 -10px 10px rgba(0,0,0,0.05));\n    mask-image: radial-gradient(circle at 10px -5px, transparent 10px, white 10.5px);\n    mask-size: 20px 100%;\n    mask-repeat: repeat-x;\n  }\n\n  .led-text {\n    font-family: var(--font-mono);\n    text-shadow: 0 0 10px rgba(7, 87, 91, 0.3);\n  }\n\n  .stacking-card {\n    position: sticky;\n    top: 15vh;\n  }\n\n  [data-lucide] {\n    display: inline-block;\n    vertical-align: middle;\n  }\n\n  /* Parallax Background Patterns */\n  .pattern-bg {\n    pointer-events: none;\n    z-index: 0;\n  }\n\n  /* SVG Path Styles */\n  .process-path {\n    filter: drop-shadow(0 0 12px rgba(102, 165, 173, 0.4));\n  }\n</style>\n\n<nav class=\"fixed top-6 left-1/2 -translate-x-1/2 z-50 bg-white/80 backdrop-blur-xl px-8 py-4 rounded-full border border-teal-100 flex items-center gap-12 card-shadow\" data-kid=\"1\">\n  <div class=\"flex items-center gap-2\" data-kid=\"2\">\n    <div class=\"w-8 h-8 bg-[#003B46] rounded-lg flex items-center justify-center\" data-kid=\"3\">\n      <i data-lucide=\"package\" class=\"w-5 h-5 text-white\" data-kid=\"4\"></i>\n    </div>\n    <span class=\"font-bold text-xl tracking-tight\" data-kid=\"5\">Stocky</span>\n  </div>\n  <div class=\"hidden md:flex items-center gap-8 font-semibold text-sm\" data-kid=\"6\">\n    <a href=\"#process\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"7\">Proceso</a>\n    <a href=\"#modules\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"8\">Módulos</a>\n    <a href=\"#downloads\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"9\">Descargas</a>\n  </div>\n  <div class=\"flex items-center gap-4\" data-kid=\"10\">\n    <button class=\"px-6 py-2 rounded-full font-bold text-sm bg-[#003B46] text-white hover:bg-[#07575B] transition-all\" data-kid=\"11\">Empezar</button>\n  </div>\n</nav>\n\n<section class=\"relative min-h-screen pt-40 pb-20 flex flex-col items-center\" data-kid=\"12\">\n  \n  <div class=\"pattern-bg absolute top-20 left-10 opacity-5\" data-parallax=\"-0.3\" data-kid=\"13\">\n    <i data-lucide=\"utensils\" class=\"w-32 h-32\" data-kid=\"14\"></i>\n  </div>\n  <div class=\"pattern-bg absolute bottom-20 right-10 opacity-5\" data-parallax=\"0.2\" data-kid=\"15\">\n    <i data-lucide=\"coffee\" class=\"w-48 h-48\" data-kid=\"16\"></i>\n  </div>\n\n  <div class=\"max-w-4xl text-center px-6 mb-16 relative z-10\" data-kid=\"17\">\n    <h1 class=\"text-6xl md:text-8xl font-extrabold tracking-tighter leading-tight mb-6\" data-kid=\"18\">\n      Control total, <span class=\"text-[#66A5AD]\" data-kid=\"19\">territorio</span> propio.\n    </h1>\n    <p class=\"text-xl text-teal-900/60 max-w-2xl mx-auto font-medium leading-relaxed\" data-kid=\"20\">\n      El sistema POS diseñado como un ecosistema modular. Vende, gestiona y escala tu restaurante, cafetería o bar con la precisión de un tablero de mando.\n    </p>\n  </div>\n\n  <div class=\"relative w-full max-w-6xl px-6\" data-kid=\"21\">\n    \n    <div class=\"widget absolute -top-12 left-4 w-48 p-4 bg-white rounded-2xl card-shadow border border-teal-50 z-20\" style=\"opacity: 0;\" data-kid=\"22\">\n      <div class=\"flex items-center gap-3 mb-3\" data-kid=\"23\">\n        <div class=\"w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center\" data-kid=\"24\">\n          <i data-lucide=\"trending-up\" class=\"w-4 h-4 text-emerald-600\" data-kid=\"25\"></i>\n        </div>\n        <span class=\"text-xs font-bold opacity-40 uppercase\" data-kid=\"26\">Ventas Hoy</span>\n      </div>\n      <div class=\"text-2xl font-extrabold\" data-kid=\"27\">$2.450</div>\n      <div class=\"mt-2 h-8 w-full bg-emerald-50 rounded-md overflow-hidden flex items-end gap-1 px-1\" data-kid=\"28\">\n        <div class=\"w-full bg-emerald-300 rounded-t-sm\" style=\"height: 40%\" data-kid=\"29\"></div>\n        <div class=\"w-full bg-emerald-400 rounded-t-sm\" style=\"height: 60%\" data-kid=\"30\"></div>\n        <div class=\"w-full bg-emerald-500 rounded-t-sm\" style=\"height: 90%\" data-kid=\"31\"></div>\n        <div class=\"w-full bg-emerald-400 rounded-t-sm\" style=\"height: 70%\" data-kid=\"32\"></div>\n      </div>\n    </div>\n\n    \n    <div class=\"widget absolute top-1/4 right-4 w-56 p-4 bg-white rounded-2xl card-shadow border border-teal-50 z-20\" style=\"opacity: 0;\" data-kid=\"33\">\n      <div class=\"flex items-center justify-between mb-4\" data-kid=\"34\">\n        <span class=\"text-xs font-bold opacity-40 uppercase\" data-kid=\"35\">Ticket Reciente</span>\n        <div class=\"w-2 h-2 rounded-full bg-orange-400 animate-pulse\" data-kid=\"36\"></div>\n      </div>\n      <div class=\"space-y-2\" data-kid=\"37\">\n        <div class=\"flex justify-between items-center text-sm font-bold\" data-kid=\"38\">\n          <span data-kid=\"39\">2x Burger Clásica</span>\n          <span data-kid=\"40\">$34.00</span>\n        </div>\n        <div class=\"flex justify-between items-center text-sm font-bold opacity-50\" data-kid=\"41\">\n          <span data-kid=\"42\">1x Soda Grande</span>\n          <span data-kid=\"43\">$4.50</span>\n        </div>\n        <hr class=\"border-teal-50\" data-kid=\"44\">\n        <div class=\"flex justify-between items-center text-lg font-extrabold\" data-kid=\"45\">\n          <span data-kid=\"46\">Total</span>\n          <span data-kid=\"47\">$38.50</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"relative w-full aspect-video bg-white p-4 rounded-[40px] card-shadow border border-teal-50 overflow-hidden\" data-kid=\"48\">\n      <video src=\"https://videos.pexels.com/video-files/6602061/6602061-sd_960_540_30fps.mp4\" poster=\"https://images.pexels.com/videos/6602061/pexels-photo-6602061.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover rounded-[32px]\" data-kid=\"49\"></video>\n      <div class=\"absolute inset-0 bg-gradient-to-t from-[#003B46]/20 to-transparent pointer-events-none\" data-kid=\"50\"></div>\n    </div>\n  </div>\n</section>\n\n<section class=\"py-16 bg-[#003B46]/5 inset-strip overflow-hidden\" data-kid=\"51\">\n  <div class=\"max-w-7xl mx-auto px-6 flex flex-wrap justify-center md:justify-between items-center gap-12\" data-kid=\"52\">\n    <div class=\"text-center md:text-left stat-item\" data-target=\"99.9\" data-kid=\"53\">\n      <div class=\"led-text text-5xl font-bold text-[#07575B] mb-1\" data-kid=\"54\">99.9%</div>\n      <div class=\"text-[10px] font-mono font-bold uppercase tracking-widest text-[#66A5AD]\" data-kid=\"55\">Uptime Garantizado</div>\n    </div>\n    <div class=\"text-center md:text-left stat-item\" data-target=\"0.4\" data-kid=\"56\">\n      <div class=\"led-text text-5xl font-bold text-[#07575B] mb-1\" data-kid=\"57\">0.4s</div>\n      <div class=\"text-[10px] font-mono font-bold uppercase tracking-widest text-[#66A5AD]\" data-kid=\"58\">Latencia de Cobro</div>\n    </div>\n    <div class=\"text-center md:text-left stat-item\" data-target=\"12000\" data-kid=\"59\">\n      <div class=\"led-text text-5xl font-bold text-[#07575B] mb-1\" data-kid=\"60\">12,000</div>\n      <div class=\"text-[10px] font-mono font-bold uppercase tracking-widest text-[#66A5AD]\" data-kid=\"61\">Ventas Diarias</div>\n    </div>\n    <div class=\"text-center md:text-left stat-item\" data-target=\"24\" data-kid=\"62\">\n      <div class=\"led-text text-5xl font-bold text-[#07575B] mb-1\" data-kid=\"63\">24/7</div>\n      <div class=\"text-[10px] font-mono font-bold uppercase tracking-widest text-[#66A5AD]\" data-kid=\"64\">Soporte Local</div>\n    </div>\n  </div>\n</section>\n\n<section id=\"process\" class=\"py-32 bg-white relative overflow-hidden\" data-kid=\"65\">\n  \n  <div class=\"absolute left-1/2 top-0 bottom-0 w-[600px] -translate-x-1/2 pointer-events-none z-0 hidden lg:block opacity-60\" data-kid=\"66\">\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 1200\" preserveAspectRatio=\"none\" class=\"overflow-visible\" data-kid=\"67\">\n      <path id=\"process-svg-path\" d=\"M300,50 C450,250 150,450 300,650 C450,850 150,1050 300,1150\" fill=\"none\" stroke=\"var(--color-accent)\" stroke-width=\"5\" stroke-dasharray=\"14 18\" stroke-linecap=\"round\" class=\"process-path\" data-kid=\"68\"></path>\n    </svg>\n  </div>\n\n  <div class=\"max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-20\" data-kid=\"69\">\n    <div class=\"md:sticky md:top-40 md:h-fit z-10\" data-kid=\"70\">\n      <h2 class=\"text-5xl font-extrabold tracking-tighter mb-8 leading-tight\" data-kid=\"71\">\n        Tu operación,<br data-kid=\"72\"><span class=\"text-[#66A5AD]\" data-kid=\"73\">paso a paso.</span>\n      </h2>\n      <p class=\"text-lg text-teal-900/60 font-medium mb-12\" data-kid=\"74\">\n        Diseñamos el flujo de trabajo más eficiente del mercado. Sin fricción, sin complicaciones, solo resultados.\n      </p>\n      <div class=\"flex gap-4\" data-kid=\"75\">\n        <div class=\"w-12 h-1 bg-[#003B46] rounded-full\" data-kid=\"76\"></div>\n        <div class=\"w-12 h-1 bg-teal-100 rounded-full\" data-kid=\"77\"></div>\n        <div class=\"w-12 h-1 bg-teal-100 rounded-full\" data-kid=\"78\"></div>\n      </div>\n    </div>\n\n    <div class=\"space-y-24 relative z-10\" data-kid=\"79\">\n      <div class=\"stacking-card p-10 bg-[#E8F4F6] rounded-[40px] border border-teal-100/50\" data-kid=\"80\">\n        <div class=\"w-16 h-16 bg-white rounded-2xl flex items-center justify-center mb-8 card-shadow-sm\" data-kid=\"81\">\n          <i data-lucide=\"package\" class=\"w-10 h-10 text-[#003B46]\" data-kid=\"82\"></i>\n        </div>\n        <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"83\">01. Carga tu inventario</h3>\n        <p class=\"text-lg text-teal-900/70 font-medium leading-relaxed\" data-kid=\"84\">\n          Sube tus productos, variantes y precios en minutos. Sincronización inmediata con todas tus terminales.\n        </p>\n      </div>\n\n      <div class=\"stacking-card p-10 bg-[#66A5AD] text-white rounded-[40px] border border-teal-300/30\" data-kid=\"85\">\n        <div class=\"w-16 h-16 bg-white/20 backdrop-blur rounded-2xl flex items-center justify-center mb-8\" data-kid=\"86\">\n          <i data-lucide=\"layout-dashboard\" class=\"w-10 h-10 text-white\" data-kid=\"87\"></i>\n        </div>\n        <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"88\">02. Vende & Controla</h3>\n        <p class=\"text-lg text-white/80 font-medium leading-relaxed\" data-kid=\"89\">\n          Interfaz optimizada para pantallas táctiles. Gestiona mesas, comandas y pagos con agilidad absoluta.\n        </p>\n      </div>\n\n      <div class=\"stacking-card p-10 bg-[#003B46] text-white rounded-[40px] card-shadow border border-teal-900 overflow-hidden relative\" data-kid=\"90\">\n        <img src=\"https://images.unsplash.com/photo-1556740714-a8395b3bf30f?auto=format&w=800&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-10 grayscale pointer-events-none\" decoding=\"async\" loading=\"lazy\" data-kid=\"91\">\n        <div class=\"relative z-10\" data-kid=\"92\">\n          <div class=\"w-16 h-16 bg-white/10 backdrop-blur rounded-2xl flex items-center justify-center mb-8\" data-kid=\"93\">\n            <i data-lucide=\"line-chart\" class=\"w-10 h-10 text-[#66A5AD]\" data-kid=\"94\"></i>\n          </div>\n          <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"95\">03. Analiza & Crece</h3>\n          <p class=\"text-lg text-white/80 font-medium leading-relaxed\" data-kid=\"96\">\n            Reportes automáticos al cierre de turno. Descubre tus platos estrella y optimiza tus márgenes.\n          </p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section id=\"modules\" class=\"py-32 bg-[#E8F4F6]\" data-kid=\"97\">\n  <div class=\"max-w-7xl mx-auto px-6 text-center mb-20\" data-kid=\"98\">\n    <span class=\"inline-block px-4 py-1 bg-white rounded-full text-[10px] font-mono font-bold uppercase tracking-widest text-[#003B46] mb-6 border border-teal-100\" data-kid=\"99\">Territorios Modulares</span>\n    <h2 class=\"text-5xl md:text-6xl font-extrabold tracking-tighter\" data-kid=\"100\">Módulos que potencian <br data-kid=\"101\"> tu <span class=\"text-[#66A5AD]\" data-kid=\"102\">negocio.</span></h2>\n  </div>\n\n  <div class=\"max-w-7xl mx-auto px-6 bento-grid\" data-kid=\"103\">\n    <div class=\"col-span-2 row-span-1 bg-white p-10 rounded-[40px] card-shadow border border-teal-50/30 flex items-center justify-between group overflow-hidden bento-card\" data-kid=\"104\">\n      <div class=\"max-w-[200px]\" data-kid=\"105\">\n        <h4 class=\"text-2xl font-bold mb-3\" data-kid=\"106\">Cobro Rápido</h4>\n        <p class=\"text-sm text-teal-900/60 font-medium\" data-kid=\"107\">Checkout en menos de 2 toques. Diseñado para alta rotación.</p>\n      </div>\n      <div class=\"relative\" data-kid=\"108\">\n        <div class=\"icon-container flex items-center justify-center\" data-kid=\"109\">\n          <i data-lucide=\"shopping-cart\" class=\"w-14 h-14 text-[#003B46]\" data-kid=\"110\"></i>\n        </div>\n        <div class=\"absolute -top-6 -right-2 bg-emerald-500 text-white text-[10px] font-mono font-bold px-2 py-1 rounded-full\" data-kid=\"111\">ACTIVE</div>\n      </div>\n    </div>\n\n    <div class=\"col-span-1 row-span-1 bg-white p-8 rounded-[40px] card-shadow border border-teal-50/30 flex flex-col justify-between bento-card\" data-kid=\"112\">\n      <div class=\"mb-4 icon-container\" data-kid=\"113\">\n        <i data-lucide=\"receipt\" class=\"w-8 h-8 text-[#07575B]\" data-kid=\"114\"></i>\n      </div>\n      <div data-kid=\"115\">\n        <h4 class=\"text-xl font-bold mb-2\" data-kid=\"116\">Facturación</h4>\n        <p class=\"text-sm text-teal-900/60 font-medium\" data-kid=\"117\">Electrónica y simplificada. 100% legal.</p>\n      </div>\n    </div>\n\n    <div class=\"col-span-1 row-span-1 bg-[#003B46] p-8 rounded-[40px] border border-teal-900 text-white bento-card\" data-kid=\"118\">\n      <div class=\"mb-4 icon-container\" data-kid=\"119\">\n        <i data-lucide=\"bar-chart-3\" class=\"w-8 h-8 text-[#66A5AD]\" data-kid=\"120\"></i>\n      </div>\n      <h4 class=\"text-xl font-bold mb-2\" data-kid=\"121\">Reportes</h4>\n      <p class=\"text-sm text-white/60 font-medium\" data-kid=\"122\">Métricas claras en tiempo real. Exporta en un click.</p>\n    </div>\n\n    <div class=\"col-span-1 row-span-1 bg-white p-8 rounded-[40px] card-shadow border border-teal-50/30 bento-card\" data-kid=\"123\">\n      <div class=\"mb-4 icon-container\" data-kid=\"124\">\n        <i data-lucide=\"users\" class=\"w-8 h-8 text-[#003B46]\" data-kid=\"125\"></i>\n      </div>\n      <h4 class=\"text-xl font-bold mb-2\" data-kid=\"126\">Empleados</h4>\n      <p class=\"text-sm text-teal-900/60 font-medium\" data-kid=\"127\">Roles y permisos definidos. Control de turnos.</p>\n    </div>\n\n    <div class=\"col-span-2 row-span-1 bg-white p-10 rounded-[40px] border border-teal-50/30 flex gap-8 items-center overflow-hidden bento-card\" data-kid=\"128\">\n      <div class=\"flex-1\" data-kid=\"129\">\n        <h4 class=\"text-2xl font-bold mb-3\" data-kid=\"130\">Información Segura</h4>\n        <p class=\"text-sm text-teal-900/60 font-medium\" data-kid=\"131\">Encriptación de grado bancario para todos tus datos sensibles y transacciones.</p>\n      </div>\n      <div class=\"icon-container flex items-center justify-center opacity-40 -mr-6\" data-kid=\"132\">\n        <i data-lucide=\"shield-check\" class=\"w-24 h-24 text-[#66A5AD]\" data-kid=\"133\"></i>\n      </div>\n    </div>\n\n    <div class=\"col-span-1 row-span-1 bg-[#66A5AD] p-8 rounded-[40px] border border-teal-300/30 text-white bento-card\" data-kid=\"134\">\n      <div class=\"mb-4 icon-container\" data-kid=\"135\">\n        <i data-lucide=\"clock\" class=\"w-8 h-8 text-white\" data-kid=\"136\"></i>\n      </div>\n      <h4 class=\"text-xl font-bold mb-2\" data-kid=\"137\">Cierre Fácil</h4>\n      <p class=\"text-sm text-white/80 font-medium\" data-kid=\"138\">Cuadre de caja automático al final del día. Sin errores.</p>\n    </div>\n  </div>\n</section>\n\n<section id=\"start\" class=\"py-40 bg-[#003B46] relative overflow-hidden flex items-center justify-center\" data-kid=\"139\">\n  <div class=\"absolute inset-0 opacity-10\" data-kid=\"140\">\n    <div class=\"pattern-bg absolute -top-20 -left-20 w-80 h-80\" data-parallax=\"-0.5\" data-kid=\"141\">\n      <i data-lucide=\"shield\" class=\"w-full h-full text-teal-100 opacity-20\" data-kid=\"142\"></i>\n    </div>\n    <div class=\"pattern-bg absolute -bottom-20 -right-20 w-80 h-80\" data-parallax=\"0.4\" data-kid=\"143\">\n      <i data-lucide=\"shield\" class=\"w-full h-full text-teal-100 opacity-20\" data-kid=\"144\"></i>\n    </div>\n  </div>\n\n  <div class=\"relative z-10 w-full max-w-2xl px-6\" data-kid=\"145\">\n    <div class=\"bg-white p-16 rounded-t-[40px] rounded-b-[40px] ticket-edge card-shadow relative\" data-kid=\"146\">\n      <div class=\"absolute -top-6 left-0 w-full h-12 bg-white flex items-center justify-around px-4 pointer-events-none\" data-kid=\"147\">\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"148\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"149\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"150\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"151\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"152\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"153\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"154\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"155\"></div>\n      </div>\n\n      <div class=\"text-center\" data-kid=\"156\">\n        <span class=\"text-xs font-bold uppercase tracking-widest text-[#66A5AD] mb-4 block\" data-kid=\"157\">ORDEN #2026-STOCKY</span>\n        <h2 class=\"text-5xl font-extrabold tracking-tighter mb-8 leading-tight\" data-kid=\"158\">¿Listo para <br data-kid=\"159\"> <span class=\"text-[#07575B]\" data-kid=\"160\">abrir?</span></h2>\n        <p class=\"text-lg text-teal-900/60 font-medium mb-12\" data-kid=\"161\">\n          Únete a los más de 500 establecimientos que ya optimizan su operación con StockyPOS.\n        </p>\n\n        <div class=\"flex justify-center gap-1 mb-12 h-12 items-center opacity-30\" data-kid=\"162\">\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"163\"></div>\n          <div class=\"w-2 h-full bg-[#003B46]\" data-kid=\"164\"></div>\n          <div class=\"w-0.5 h-full bg-[#003B46]\" data-kid=\"165\"></div>\n          <div class=\"w-3 h-full bg-[#003B46]\" data-kid=\"166\"></div>\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"167\"></div>\n          <div class=\"w-4 h-full bg-[#003B46]\" data-kid=\"168\"></div>\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"169\"></div>\n          <div class=\"w-2 h-full bg-[#003B46]\" data-kid=\"170\"></div>\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"171\"></div>\n          <div class=\"w-3 h-full bg-[#003B46]\" data-kid=\"172\"></div>\n          <div class=\"w-0.5 h-full bg-[#003B46]\" data-kid=\"173\"></div>\n          <div class=\"w-2 h-full bg-[#003B46]\" data-kid=\"174\"></div>\n        </div>\n\n        <div class=\"flex flex-col sm:flex-row gap-4 justify-center\" data-kid=\"175\">\n          <button id=\"cta-primary\" class=\"px-12 py-5 bg-[#003B46] text-white rounded-2xl font-bold text-lg card-shadow\" data-kid=\"176\">Empieza Gratis</button>\n          <button id=\"cta-secondary\" class=\"px-12 py-5 border-2 border-[#003B46] text-[#003B46] rounded-2xl font-bold text-lg\" data-kid=\"177\">Ver Demo</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<footer class=\"py-20 bg-white border-t border-teal-50\" data-kid=\"178\">\n  <div class=\"max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"179\">\n    <div class=\"col-span-2\" data-kid=\"180\">\n      <div class=\"flex items-center gap-2 mb-6\" data-kid=\"181\">\n        <div class=\"w-10 h-10 bg-[#003B46] rounded-xl flex items-center justify-center\" data-kid=\"182\">\n          <i data-lucide=\"package\" class=\"w-6 h-6 text-white\" data-kid=\"183\"></i>\n        </div>\n        <span class=\"font-extrabold text-2xl tracking-tighter\" data-kid=\"184\">Stocky</span>\n      </div>\n      <p class=\"text-teal-900/50 max-w-sm font-medium leading-relaxed\" data-kid=\"185\">\n        El ecosistema digital definitivo para la industria gastronómica. Nacido en Medellín, diseñado para el mundo.\n      </p>\n    </div>\n    \n    <div class=\"text-center md:text-left\" data-kid=\"186\">\n      <h5 class=\"font-bold text-sm uppercase tracking-widest text-[#66A5AD] mb-6\" data-kid=\"187\">Legal</h5>\n      <ul class=\"space-y-4 text-sm font-semibold\" data-kid=\"188\">\n        <li data-kid=\"189\"><a href=\"#\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"190\">Privacidad</a></li>\n        <li data-kid=\"191\"><a href=\"#\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"192\">Términos</a></li>\n        <li data-kid=\"193\"><a href=\"#\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"194\">Cookies</a></li>\n      </ul>\n    </div>\n    \n    <div class=\"flex flex-col items-center md:items-end justify-start\" data-kid=\"195\">\n      <h5 class=\"font-bold text-[10px] font-mono uppercase tracking-widest text-[#66A5AD] mb-6\" data-kid=\"196\">Social</h5>\n      <div class=\"flex gap-6 text-[#003B46]\" data-kid=\"197\">\n        <i data-lucide=\"instagram\" class=\"w-5 h-5 cursor-pointer hover:text-[#66A5AD]\" data-kid=\"198\"></i>\n        <i data-lucide=\"twitter\" class=\"w-5 h-5 cursor-pointer hover:text-[#66A5AD]\" data-kid=\"199\"></i>\n        <i data-lucide=\"linkedin\" class=\"w-5 h-5 cursor-pointer hover:text-[#66A5AD]\" data-kid=\"200\"></i>\n      </div>\n    </div>\n  </div>\n  <div class=\"max-w-7xl mx-auto px-6 mt-20 pt-8 border-t border-teal-50 flex flex-col md:flex-row justify-between items-center gap-4\" data-kid=\"201\">\n    <p class=\"text-xs font-bold text-teal-900/30\" data-kid=\"202\">© 2026 STOCKY POS. TODOS LOS DERECHOS RESERVADOS.</p>\n  </div>\n</footer>\n\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"203\"></script>\n<script type=\"module\" data-kid=\"204\">\n  import { animate, scroll, inView, hover } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  // Initialize Lucide Icons\n  lucide.createIcons();\n\n  // 1. Spring Drop-in for hero widgets + Ambient float\n  const widgets = document.querySelectorAll(\".widget\");\n  widgets.forEach((w, i) => {\n    animate(w, \n      { y: [-120, 0], opacity: [0, 1], scale: [0.8, 1] }, \n      { \n        delay: 0.4 + (i * 0.2), \n        type: \"spring\", \n        stiffness: 160, \n        damping: 14,\n        onComplete: () => {\n          // Subtle ambient floating after landing\n          animate(w, \n            { y: [0, -15, 0] }, \n            { duration: 4 + i, repeat: Infinity, ease: \"easeInOut\" }\n          );\n        }\n      }\n    );\n  });\n\n  // 2. Parallax Effects\n  // Foreground widgets parallax\n  document.querySelectorAll('.widget').forEach(w => {\n    scroll(animate(w, { y: [0, -40] }), {\n      target: w,\n      offset: [\"start end\", \"end start\"]\n    });\n  });\n\n  // Background patterns parallax + rotation\n  document.querySelectorAll('[data-parallax]').forEach(el => {\n    const speed = parseFloat(el.dataset.parallax);\n    scroll(animate(el, { y: [0, speed * 250], rotate: [0, speed * 45] }), {\n      target: el.parentElement,\n      offset: [\"start end\", \"end start\"]\n    });\n  });\n\n  // 3. SVG Path Reveal (Process Section)\n  const path = document.querySelector('#process-svg-path');\n  if(path) {\n    const pathLength = path.getTotalLength();\n    path.style.strokeDasharray = pathLength;\n    path.style.strokeDashoffset = pathLength;\n    \n    scroll(\n      animate(path, { strokeDashoffset: [pathLength, 0] }),\n      { \n        target: document.querySelector('#process'), \n        offset: [\"start center\", \"end center\"] \n      }\n    );\n  }\n\n  // 4. Stacking Cards Logic (Opacity/Scale reduction on scroll)\n  const processCards = document.querySelectorAll(\".stacking-card\");\n  processCards.forEach((card, index) => {\n    if (index === processCards.length - 1) return;\n    scroll(\n      animate(card, { scale: [1, 0.92], opacity: [1, 0.4] }),\n      {\n        target: processCards[index + 1],\n        offset: [\"start 60%\", \"start 20%\"]\n      }\n    );\n  });\n\n  // 5. Stat Counter (InView)\n  inView(\".stat-item\", ({ target }) => {\n    const finalVal = parseFloat(target.dataset.target);\n    const textEl = target.querySelector('.led-text');\n    const isFloat = target.dataset.target.includes('.');\n    \n    animate(0, finalVal, {\n      duration: 1.5,\n      onUpdate: (latest) => {\n        if (isFloat) {\n          textEl.innerText = latest.toFixed(1) + (target.dataset.target.includes('%') ? '%' : '');\n        } else {\n          textEl.innerText = Math.round(latest).toLocaleString();\n        }\n      }\n    });\n  });\n\n  // 6. Bento Card & CTA Hover Effects (Tactile Spring)\n  const interactiveEls = [\n    { selector: '.bento-card', lift: -16, scale: 1.03 },\n    { selector: '#cta-primary', lift: -6, scale: 1.05 },\n    { selector: '#cta-secondary', lift: -4, scale: 1.02 }\n  ];\n\n  interactiveEls.forEach(({ selector, lift, scale }) => {\n    document.querySelectorAll(selector).forEach(el => {\n      hover(el, \n        () => {\n          animate(el, { y: lift, scale: scale }, { type: \"spring\", stiffness: 450, damping: 18 });\n          const icon = el.querySelector('.icon-container');\n          if (icon) animate(icon, { rotate: [0, -15, 15, -10, 10, 0], scale: 1.15 }, { duration: 0.6, type: \"spring\" });\n        },\n        () => {\n          animate(el, { y: 0, scale: 1 }, { type: \"spring\", stiffness: 400, damping: 24 });\n          const icon = el.querySelector('.icon-container');\n          if (icon) animate(icon, { rotate: 0, scale: 1 }, { duration: 0.4 });\n        }\n      );\n    });\n  });\n\n  // Fade up reveal for sections\n  inView(\"section h2, section p, .bento-grid > div\", ({ target }) => {\n    animate(target, { opacity: [0, 1], y: [40, 0] }, { duration: 0.8, delay: 0.1, ease: \"easeOut\" });\n  }, { amount: 0.2 });\n\n</script>\n",

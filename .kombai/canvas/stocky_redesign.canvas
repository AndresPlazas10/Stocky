      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@500&family=Encode+Sans:wght@700;800&display=swap');\n\n  :root {\n    --color-bg: #E8F4F6;\n    --color-card: #FFFFFF;\n    --color-primary: #003B46;\n    --color-secondary: #07575B;\n    --color-accent: #66A5AD;\n    --font-sans: 'Inter', sans-serif;\n    --font-mono: 'JetBrains Mono', monospace;\n    --font-heading: 'Encode Sans', sans-serif;\n  }\n\n  body {\n    background-color: var(--color-bg);\n    color: var(--color-primary);\n    font-family: var(--font-sans);\n    margin: 0;\n    overflow-x: clip; /* Fix for sticky as per guidelines */\n  }\n\n  .bento-grid {\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    grid-auto-rows: 120px;\n    gap: 0; /* Tight Swiss grid */\n  }\n\n  .card-shadow {\n    box-shadow: 16px 16px 0px rgba(0, 59, 70, 0.03);\n  }\n\n  .inset-strip {\n    box-shadow: inset 0 4px 12px rgba(0, 0, 0, 0.05);\n  }\n\n  .notched-corner {\n    clip-path: polygon(\n      0 20px, 20px 0,\n      calc(100% - 20px) 0, 100% 20px,\n      100% calc(100% - 20px), calc(100% - 20px) 100%,\n      20px 100%, 0 calc(100% - 20px)\n    );\n  }\n\n  .led-text {\n    font-family: var(--font-mono);\n    text-shadow: 0 0 10px rgba(7, 87, 91, 0.2);\n  }\n\n  .stacking-card {\n    position: sticky;\n    top: 15vh;\n  }\n\n  /* Precision Overrides */\n  .hairline-border {\n    border: 1px solid rgba(0, 59, 70, 0.12);\n  }\n\n  .color-sweep-btn {\n    position: relative;\n    overflow: hidden;\n    z-index: 1;\n    transition: none !important;\n  }\n\n  .module-card {\n    cursor: pointer;\n    overflow: hidden;\n    border-right: 1px solid rgba(0, 59, 70, 0.1);\n    border-bottom: 1px solid rgba(0, 59, 70, 0.1);\n  }\n\n  .module-card:nth-child(4n) {\n    border-right: none;\n  }\n\n  .js-scramble-target {\n    min-height: 1.2em;\n    font-variant-numeric: tabular-nums;\n  }\n\n  .crosshair-corner::before, .crosshair-corner::after {\n    content: '';\n    position: absolute;\n    width: 10px;\n    height: 1px;\n    background: rgba(0, 59, 70, 0.3);\n  }\n  .crosshair-corner::before { left: -5px; top: 0; }\n  .crosshair-corner::after { left: 0; top: -5px; width: 1px; height: 10px; }\n</style>\n\n\n<nav class=\"fixed top-6 left-1/2 -translate-x-1/2 z-50 bg-white/80 backdrop-blur-xl px-8 py-4 rounded-full border border-teal-100 flex items-center gap-12 card-shadow\" id=\"main-nav\" data-kid=\"1\">\n  <div class=\"flex items-center gap-2\" data-kid=\"2\">\n    <div class=\"w-8 h-8 bg-[#003B46] rounded-lg flex items-center justify-center\" data-kid=\"3\">\n      <i data-lucide=\"package\" class=\"w-5 h-5 text-white\" data-kid=\"4\"></i>\n    </div>\n    <span class=\"font-bold text-xl tracking-tight\" data-kid=\"5\">Stocky</span>\n  </div>\n  <div class=\"hidden md:flex items-center gap-8 font-semibold text-sm\" data-kid=\"6\">\n    <a href=\"#process\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"7\">Proceso</a>\n    <a href=\"#modules\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"8\">Módulos</a>\n    <a href=\"#downloads\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"9\">Descargas</a>\n  </div>\n  <div class=\"flex items-center gap-4\" data-kid=\"10\">\n    <button class=\"color-sweep-btn px-6 py-2 rounded-full font-bold text-sm bg-[#003B46] text-white\" data-kid=\"11\">Empezar</button>\n  </div>\n</nav>\n\n\n<section class=\"relative min-h-screen pt-40 pb-20 border-b border-[#003B46]/10\" data-kid=\"12\">\n  <div class=\"max-w-7xl mx-auto px-6 grid grid-cols-12 gap-0 border-x border-[#003B46]/10 min-h-[600px]\" data-kid=\"13\">\n    \n    <div class=\"col-span-12 lg:col-span-7 p-12 flex flex-col justify-center border-r border-[#003B46]/10 relative\" data-kid=\"14\">\n      <div class=\"absolute top-4 right-4 text-[9px] font-mono opacity-20\" data-kid=\"15\">COORD_X: 45.23 // COORD_Y: 12.89</div>\n      <div class=\"absolute top-0 right-0 w-8 h-8 border-b border-l border-[#003B46]/20\" data-kid=\"16\"></div>\n      <span class=\"text-[10px] font-bold tracking-[0.3em] uppercase text-[#66A5AD] mb-8 flex items-center gap-2\" data-kid=\"17\">\n        <span class=\"w-2 h-2 bg-[#0BDA51] rounded-full\" data-kid=\"18\"></span>\n        Ecosistema Operativo v4.0\n      </span>\n      <h1 class=\"text-5xl md:text-7xl font-extrabold tracking-tighter leading-[0.9] mb-8 js-scramble-target\" id=\"hero-headline\" data-kid=\"19\">\n        Control total,<br data-kid=\"20\"><span class=\"text-[#66A5AD]\" data-kid=\"21\">territorio</span> propio.\n      </h1>\n      <p class=\"text-lg text-teal-900/60 max-w-lg font-medium leading-relaxed mb-12 opacity-0 js-reveal-up\" data-kid=\"22\">\n        El sistema POS diseñado como un ecosistema modular. Vende, gestiona y escala tu restaurante con la precisión de un tablero de mando.\n      </p>\n      <div class=\"flex gap-4 opacity-0 js-reveal-up\" data-kid=\"23\">\n        <button class=\"color-sweep-btn px-8 py-4 bg-[#003B46] text-white font-bold text-sm tracking-widest uppercase\" data-kid=\"24\">Sistema de Inicio</button>\n        <button class=\"px-8 py-4 border border-[#003B46] text-[#003B46] font-bold text-sm tracking-widest uppercase hover:bg-[#E8F4F6] transition-colors\" data-kid=\"25\">Ver Documentación</button>\n      </div>\n    </div>\n\n    \n    <div class=\"col-span-12 lg:col-span-5 bg-[#E8F4F6]/30 flex flex-col\" data-kid=\"26\">\n      \n      <div class=\"p-8 border-b border-[#003B46]/10 flex-1 relative overflow-hidden group\" data-kid=\"27\">\n        <div class=\"absolute inset-0 bg-white/40 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"28\"></div>\n        <div class=\"flex justify-between items-start mb-12\" data-kid=\"29\">\n          <div data-kid=\"30\">\n            <span class=\"text-[9px] font-bold text-[#66A5AD] uppercase block mb-1\" data-kid=\"31\">Live Revenue Stream</span>\n            <div class=\"text-4xl font-black text-[#003B46] js-counter-currency\" data-value=\"2450.80\" data-kid=\"32\">$0.00</div>\n          </div>\n          <div class=\"w-12 h-12 bg-white rounded-lg border border-[#003B46]/10 flex items-center justify-center\" data-kid=\"33\">\n            <i data-lucide=\"activity\" class=\"w-6 h-6 text-[#0BDA51]\" data-kid=\"34\"></i>\n          </div>\n        </div>\n        <div class=\"h-32 w-full flex items-end gap-2 px-1\" data-kid=\"35\">\n          <div class=\"bar-fill flex-1 bg-[#003B46]/20 rounded-t-xs\" style=\"height: 0%\" data-value=\"40\" data-kid=\"36\"></div>\n          <div class=\"bar-fill flex-1 bg-[#003B46]/40 rounded-t-xs\" style=\"height: 0%\" data-value=\"65\" data-kid=\"37\"></div>\n          <div class=\"bar-fill flex-1 bg-[#003B46]/60 rounded-t-xs\" style=\"height: 0%\" data-value=\"95\" data-kid=\"38\"></div>\n          <div class=\"bar-fill flex-1 bg-[#0BDA51] rounded-t-xs\" style=\"height: 0%\" data-value=\"80\" data-kid=\"39\"></div>\n        </div>\n      </div>\n      \n      <div class=\"h-[280px] relative overflow-hidden group\" data-kid=\"40\">\n        <video src=\"https://videos.pexels.com/video-files/6602061/6602061-sd_960_540_30fps.mp4\" poster=\"https://images.pexels.com/videos/6602061/pexels-photo-6602061.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700\" data-kid=\"41\"></video>\n        <div class=\"absolute inset-0 bg-[#003B46]/20 mix-blend-multiply group-hover:opacity-0 transition-opacity\" data-kid=\"42\"></div>\n        <div class=\"absolute bottom-4 left-4 text-[9px] font-mono text-white/60 tracking-widest\" data-kid=\"43\">CAM_01 // TERMINAL_ACTIVE</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-16 bg-white border-y border-[#003B46]/10 overflow-hidden\" data-kid=\"44\">\n  <div class=\"max-w-7xl mx-auto px-6 flex flex-wrap justify-center md:justify-between items-center gap-0 divide-x divide-[#003B46]/10\" data-kid=\"45\">\n    <div class=\"px-12 py-6 text-center md:text-left stat-item flex-1\" data-kid=\"46\">\n      <div class=\"led-text text-5xl font-bold text-[#07575B] mb-2 js-counter-number\" data-value=\"99.9\" data-suffix=\"%\" data-kid=\"47\">0.0%</div>\n      <div class=\"text-[11px] font-bold uppercase tracking-[0.15em] text-[#66A5AD]\" data-kid=\"48\">System Uptime</div>\n    </div>\n    <div class=\"px-12 py-6 text-center md:text-left stat-item flex-1\" data-kid=\"49\">\n      <div class=\"led-text text-5xl font-bold text-[#07575B] mb-2 js-counter-number\" data-value=\"0.4\" data-suffix=\"s\" data-kid=\"50\">0.0s</div>\n      <div class=\"text-[11px] font-bold uppercase tracking-[0.15em] text-[#66A5AD]\" data-kid=\"51\">Network Latency</div>\n    </div>\n    <div class=\"px-12 py-6 text-center md:text-left stat-item flex-1\" data-kid=\"52\">\n      <div class=\"led-text text-5xl font-bold text-[#07575B] mb-2 js-counter-number\" data-value=\"12000\" data-prefix=\"+\" data-format=\"short\" data-kid=\"53\">0</div>\n      <div class=\"text-[11px] font-bold uppercase tracking-[0.15em] text-[#66A5AD]\" data-kid=\"54\">Daily Transactions</div>\n    </div>\n    <div class=\"px-12 py-6 text-center md:text-left stat-item flex-1\" data-kid=\"55\">\n      <div class=\"led-text text-5xl font-bold text-[#07575B] mb-2 js-scramble-small\" data-text=\"24/7\" data-kid=\"56\">--/--</div>\n      <div class=\"text-[11px] font-bold uppercase tracking-[0.15em] text-[#66A5AD]\" data-kid=\"57\">Technical Support</div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"process\" class=\"py-32 bg-white\" data-kid=\"58\">\n  <div class=\"max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-20\" data-kid=\"59\">\n    <div class=\"md:sticky md:top-40 md:h-fit\" data-kid=\"60\">\n      <h2 class=\"text-5xl font-extrabold tracking-tighter mb-8 leading-tight js-reveal-up\" data-kid=\"61\">\n        Tu operación,<br data-kid=\"62\"><span class=\"text-[#66A5AD]\" data-kid=\"63\">paso a paso.</span>\n      </h2>\n      <p class=\"text-lg text-teal-900/60 font-medium mb-12 js-reveal-up\" data-kid=\"64\">\n        Diseñamos el flujo de trabajo más eficiente del mercado. Sin fricción, sin complicaciones, solo resultados.\n      </p>\n      <div class=\"flex gap-4\" data-kid=\"65\">\n        <div class=\"w-12 h-1 bg-[#003B46] rounded-full\" data-kid=\"66\"></div>\n        <div class=\"w-12 h-1 bg-teal-100 rounded-full\" data-kid=\"67\"></div>\n        <div class=\"w-12 h-1 bg-teal-100 rounded-full\" data-kid=\"68\"></div>\n      </div>\n    </div>\n\n    <div class=\"space-y-24\" data-kid=\"69\">\n      \n      <div class=\"stacking-card p-10 bg-[#E8F4F6] rounded-[40px] card-shadow border border-teal-100\" data-kid=\"70\">\n        <div class=\"absolute top-8 right-10 text-[10px] font-mono font-bold opacity-30\" data-kid=\"71\">HEX_STEP // 0x01</div>\n        <div class=\"w-16 h-16 bg-white rounded-2xl flex items-center justify-center mb-8 shadow-sm\" data-kid=\"72\">\n          <i data-lucide=\"package\" class=\"w-10 h-10 text-[#003B46]\" data-kid=\"73\"></i>\n        </div>\n        <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"74\">01. Carga tu inventario</h3>\n        <p class=\"text-lg text-teal-900/70 font-medium leading-relaxed\" data-kid=\"75\">\n          Sube tus productos, variantes y precios en minutos. Sincronización inmediata con todas tus terminales.\n        </p>\n      </div>\n\n      <div class=\"stacking-card p-10 bg-[#66A5AD] text-white rounded-[40px] card-shadow border border-teal-300\" data-kid=\"76\">\n        <div class=\"absolute top-8 right-10 text-[10px] font-mono font-bold opacity-30\" data-kid=\"77\">HEX_STEP // 0x02</div>\n        <div class=\"w-16 h-16 bg-white/20 backdrop-blur rounded-2xl flex items-center justify-center mb-8\" data-kid=\"78\">\n          <i data-lucide=\"layout-dashboard\" class=\"w-10 h-10 text-white\" data-kid=\"79\"></i>\n        </div>\n        <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"80\">02. Vende & Controla</h3>\n        <p class=\"text-lg text-white/80 font-medium leading-relaxed\" data-kid=\"81\">\n          Interfaz optimizada para pantallas táctiles. Gestiona mesas, comandas y pagos con agilidad absoluta.\n        </p>\n      </div>\n\n      <div class=\"stacking-card p-10 bg-[#003B46] text-white rounded-[40px] card-shadow border border-teal-900 overflow-hidden relative\" data-kid=\"82\">\n        <img src=\"https://images.unsplash.com/photo-1556740714-a8395b3bf30f?auto=format&w=800&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-10 grayscale pointer-events-none\" decoding=\"async\" loading=\"lazy\" data-kid=\"83\">\n        <div class=\"relative z-10\" data-kid=\"84\">\n          <div class=\"w-16 h-16 bg-white/10 backdrop-blur rounded-2xl flex items-center justify-center mb-8\" data-kid=\"85\">\n            <i data-lucide=\"line-chart\" class=\"w-10 h-10 text-[#66A5AD]\" data-kid=\"86\"></i>\n          </div>\n          <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"87\">03. Analiza & Crece</h3>\n          <p class=\"text-lg text-white/80 font-medium leading-relaxed\" data-kid=\"88\">\n            Reportes automáticos al cierre de turno. Descubre tus platos estrella y optimiza tus márgenes.\n          </p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"modules\" class=\"py-32 bg-white border-b border-[#003B46]/10\" data-kid=\"89\">\n  <div class=\"max-w-7xl mx-auto px-6 text-center mb-20\" data-kid=\"90\">\n    <span class=\"inline-block px-4 py-1 bg-[#E8F4F6] rounded-full text-[10px] font-bold uppercase tracking-[0.2em] text-[#003B46] mb-6 border border-[#003B46]/10\" data-kid=\"91\">Módulos de Sistema [v4.0]</span>\n    <h2 class=\"text-5xl md:text-6xl font-extrabold tracking-tighter js-reveal-up\" data-kid=\"92\">Funcionalidades de <span class=\"text-[#66A5AD]\" data-kid=\"93\">Precisión.</span></h2>\n  </div>\n\n  <div class=\"max-w-7xl mx-auto px-6 bento-grid border-l border-t border-[#003B46]/10\" id=\"bento-container\" data-kid=\"94\">\n    <div class=\"module-card col-span-12 md:col-span-6 row-span-2 bg-[#E8F4F6]/20 p-12 flex items-center justify-between group relative overflow-hidden\" data-kid=\"95\">\n      <div class=\"absolute top-6 left-6 text-[9px] font-mono font-bold opacity-30 tracking-widest\" data-kid=\"96\">MODULE_ID // 0x01_CHECKOUT</div>\n      <div class=\"max-w-[280px] relative z-10\" data-kid=\"97\">\n        <h4 class=\"text-3xl font-black mb-4\" data-kid=\"98\">Cobro Dinámico</h4>\n        <p class=\"text-sm text-teal-900/60 font-medium leading-relaxed\" data-kid=\"99\">Arquitectura de checkout ultra-veloz. Procesamiento asíncrono en menos de 0.4s por transacción.</p>\n      </div>\n      <div class=\"relative z-10\" data-kid=\"100\">\n        <div class=\"w-32 h-32 bg-white rounded-full flex items-center justify-center icon-container border border-[#003B46]/10 shadow-sm\" data-kid=\"101\">\n          <i data-lucide=\"shopping-cart\" class=\"w-12 h-12 text-[#003B46]\" data-kid=\"102\"></i>\n        </div>\n        <div class=\"absolute -top-2 -right-2 bg-[#0BDA51] text-black text-[9px] font-black px-3 py-1 rounded-full tracking-tighter\" data-kid=\"103\">STATUS: ACTIVE</div>\n      </div>\n    </div>\n\n    <div class=\"module-card col-span-12 md:col-span-3 row-span-2 bg-white p-8 flex flex-col justify-between group relative\" data-kid=\"104\">\n      <div class=\"absolute top-6 left-6 text-[9px] font-mono font-bold opacity-30 tracking-widest\" data-kid=\"105\">MODULE_ID // 0x02_TAX</div>\n      <div class=\"w-16 h-16 bg-[#E8F4F6] rounded-2xl flex items-center justify-center mb-6 icon-container\" data-kid=\"106\">\n        <i data-lucide=\"receipt\" class=\"w-8 h-8 text-[#07575B]\" data-kid=\"107\"></i>\n      </div>\n      <div data-kid=\"108\">\n        <h4 class=\"text-xl font-bold mb-2\" data-kid=\"109\">Facturación Fiscal</h4>\n        <p class=\"text-xs text-teal-900/60 font-medium\" data-kid=\"110\">Certificación electrónica 100% automatizada.</p>\n      </div>\n    </div>\n\n    <div class=\"module-card col-span-12 md:col-span-3 row-span-2 bg-[#003B46] p-8 text-white group relative\" data-kid=\"111\">\n      <div class=\"absolute top-6 left-6 text-[9px] font-mono font-bold opacity-30 tracking-widest\" data-kid=\"112\">MODULE_ID // 0x03_ANALYTICS</div>\n      <div class=\"w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center mb-6 icon-container\" data-kid=\"113\">\n        <i data-lucide=\"bar-chart-3\" class=\"w-8 h-8 text-[#66A5AD]\" data-kid=\"114\"></i>\n      </div>\n      <div data-kid=\"115\">\n        <h4 class=\"text-xl font-bold mb-2\" data-kid=\"116\">Reportes Core</h4>\n        <p class=\"text-xs text-white/50 font-medium\" data-kid=\"117\">Exportación tabular en formatos JSON/CSV/PDF.</p>\n      </div>\n    </div>\n\n    <div class=\"module-card col-span-12 md:col-span-4 row-span-2 bg-white p-10 flex gap-8 items-center group relative border-t border-[#003B46]/10\" data-kid=\"118\">\n      <div class=\"absolute top-6 left-6 text-[9px] font-mono font-bold opacity-30 tracking-widest\" data-kid=\"119\">MODULE_ID // 0x04_SEC</div>\n      <div class=\"flex-1 mt-6\" data-kid=\"120\">\n        <h4 class=\"text-2xl font-bold mb-3\" data-kid=\"121\">Cifrado de Grado</h4>\n        <p class=\"text-xs text-teal-900/60 font-medium\" data-kid=\"122\">AES-256 bits para todas las transacciones de tarjeta.</p>\n      </div>\n      <div class=\"w-20 h-20 bg-teal-50 rounded-2xl flex items-center justify-center border-2 border-dashed border-teal-100 icon-container\" data-kid=\"123\">\n        <i data-lucide=\"shield-check\" class=\"w-10 h-10 text-[#66A5AD]\" data-kid=\"124\"></i>\n      </div>\n    </div>\n\n    <div class=\"module-card col-span-12 md:col-span-8 row-span-2 bg-[#66A5AD] p-10 text-white group relative\" data-kid=\"125\">\n      <div class=\"absolute top-6 left-6 text-[9px] font-mono font-bold opacity-30 tracking-widest\" data-kid=\"126\">MODULE_ID // 0x05_TIME</div>\n      <div class=\"flex items-center justify-between mt-6\" data-kid=\"127\">\n        <div class=\"max-w-[300px]\" data-kid=\"128\">\n          <h4 class=\"text-2xl font-bold mb-3\" data-kid=\"129\">Gestión de Turnos</h4>\n          <p class=\"text-xs text-white/70 font-medium\" data-kid=\"130\">Algoritmo de optimización de cuadrante para staff de alta rotación.</p>\n        </div>\n        <div class=\"w-24 h-24 bg-white/20 rounded-full flex items-center justify-center icon-container border border-white/20 backdrop-blur-sm\" data-kid=\"131\">\n          <i data-lucide=\"clock\" class=\"w-10 h-10 text-white\" data-kid=\"132\"></i>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n\n<section id=\"start\" class=\"py-40 bg-[#003B46] relative overflow-hidden flex items-center justify-center border-t border-white/10\" data-kid=\"133\">\n  <div class=\"absolute inset-0 opacity-5\" data-kid=\"134\">\n    <div class=\"w-full h-full\" style=\"background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 32px 32px;\" data-kid=\"135\"></div>\n  </div>\n\n  <div class=\"relative z-10 w-full max-w-3xl px-6\" data-kid=\"136\">\n    <div class=\"bg-white p-16 notched-corner card-shadow relative\" data-kid=\"137\">\n      <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 w-32 h-8 bg-[#0BDA51] notched-corner flex items-center justify-center\" data-kid=\"138\">\n        <span class=\"text-[9px] font-black uppercase tracking-widest text-[#003B46]\" data-kid=\"139\">System Ready</span>\n      </div>\n      <div class=\"absolute top-12 left-12 w-8 h-8 border-t border-l border-[#003B46]/20\" data-kid=\"140\"></div>\n      <div class=\"absolute bottom-12 right-12 w-8 h-8 border-b border-r border-[#003B46]/20\" data-kid=\"141\"></div>\n\n      <div class=\"text-center\" data-kid=\"142\">\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"143\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"144\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"145\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"146\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"147\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"148\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"149\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"150\"></div>\n      </div>\n\n      <div class=\"text-center\" data-kid=\"151\">\n        <span class=\"text-xs font-bold uppercase tracking-widest text-[#66A5AD] mb-4 block\" data-kid=\"152\">ORDEN #2026-STOCKY</span>\n        <h2 class=\"text-5xl font-extrabold tracking-tighter mb-8 leading-tight js-reveal-up\" data-kid=\"153\">¿Listo para <br data-kid=\"154\"> <span class=\"text-[#07575B]\" data-kid=\"155\">abrir?</span></h2>\n        <p class=\"text-lg text-teal-900/60 font-medium mb-12 js-reveal-up\" data-kid=\"156\">\n          Únete a los más de 500 establecimientos que ya optimizan su operación con StockyPOS.\n        </p>\n\n        <div class=\"flex justify-center gap-1 mb-12 h-12 items-center opacity-30\" data-kid=\"157\">\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"158\"></div>\n          <div class=\"w-2 h-full bg-[#003B46]\" data-kid=\"159\"></div>\n          <div class=\"w-0.5 h-full bg-[#003B46]\" data-kid=\"160\"></div>\n          <div class=\"w-3 h-full bg-[#003B46]\" data-kid=\"161\"></div>\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"162\"></div>\n          <div class=\"w-4 h-full bg-[#003B46]\" data-kid=\"163\"></div>\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"164\"></div>\n          <div class=\"w-2 h-full bg-[#003B46]\" data-kid=\"165\"></div>\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"166\"></div>\n          <div class=\"w-3 h-full bg-[#003B46]\" data-kid=\"167\"></div>\n          <div class=\"w-0.5 h-full bg-[#003B46]\" data-kid=\"168\"></div>\n          <div class=\"w-2 h-full bg-[#003B46]\" data-kid=\"169\"></div>\n        </div>\n\n        <div class=\"flex flex-col sm:flex-row gap-4 justify-center\" data-kid=\"170\">\n          <button class=\"color-sweep-btn px-12 py-5 bg-[#003B46] text-white rounded-2xl font-bold text-lg card-shadow\" data-kid=\"171\">Empieza Gratis</button>\n          <button class=\"color-sweep-btn-outline px-12 py-5 border-2 border-[#003B46] text-[#003B46] rounded-2xl font-bold text-lg\" data-kid=\"172\">Ver Demo</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"py-20 bg-white border-t border-teal-50\" data-kid=\"173\">\n  <div class=\"max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"174\">\n    <div class=\"col-span-2\" data-kid=\"175\">\n      <div class=\"flex items-center gap-2 mb-6\" data-kid=\"176\">\n        <div class=\"w-10 h-10 bg-[#003B46] rounded-xl flex items-center justify-center\" data-kid=\"177\">\n          <i data-lucide=\"package\" class=\"w-6 h-6 text-white\" data-kid=\"178\"></i>\n        </div>\n        <span class=\"font-extrabold text-2xl tracking-tighter\" data-kid=\"179\">Stocky</span>\n      </div>\n      <p class=\"text-teal-900/50 max-w-sm font-medium leading-relaxed\" data-kid=\"180\">\n        El ecosistema digital definitivo para la industria gastronómica. Nacido en Medellín, diseñado para el mundo.\n      </p>\n    </div>\n    \n    <div class=\"text-center md:text-left\" data-kid=\"181\">\n      <h5 class=\"font-bold text-sm uppercase tracking-widest text-[#66A5AD] mb-6\" data-kid=\"182\">Legal</h5>\n      <ul class=\"space-y-4 text-sm font-semibold\" data-kid=\"183\">\n        <li data-kid=\"184\"><a href=\"#\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"185\">Privacidad</a></li>\n        <li data-kid=\"186\"><a href=\"#\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"187\">Términos</a></li>\n        <li data-kid=\"188\"><a href=\"#\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"189\">Cookies</a></li>\n      </ul>\n    </div>\n    \n    <div class=\"flex flex-col items-center md:items-end justify-start\" data-kid=\"190\">\n      <div class=\"flex gap-6 text-[#003B46]\" data-kid=\"191\">\n        <i data-lucide=\"instagram\" class=\"w-5 h-5 cursor-pointer hover:text-[#66A5AD] transition-colors\" data-kid=\"192\"></i>\n        <i data-lucide=\"twitter\" class=\"w-5 h-5 cursor-pointer hover:text-[#66A5AD] transition-colors\" data-kid=\"193\"></i>\n        <i data-lucide=\"linkedin\" class=\"w-5 h-5 cursor-pointer hover:text-[#66A5AD] transition-colors\" data-kid=\"194\"></i>\n      </div>\n    </div>\n  </div>\n  <div class=\"max-w-7xl mx-auto px-6 mt-20 pt-8 border-t border-teal-50 flex flex-col md:flex-row justify-between items-center gap-4\" data-kid=\"195\">\n    <p class=\"text-xs font-bold text-teal-900/30\" data-kid=\"196\">© 2026 STOCKY POS. TODOS LOS DERECHOS RESERVADOS.</p>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"197\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"198\"></script>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"199\"></script>\n\n<script type=\"module\" data-kid=\"200\">\n  import { animate, createTimeline, stagger, scrambleText, onScroll, utils } from 'https://esm.sh/animejs@4';\n\n  // Initialize Icons\n  lucide.createIcons();\n\n  // GSAP for Stacking Cards (as it's already implemented well in ref)\n  gsap.registerPlugin(ScrollTrigger);\n  const cards = gsap.utils.toArray(\".stacking-card\");\n  cards.forEach((card, index) => {\n    if (index === cards.length - 1) return;\n    gsap.to(card, {\n      scale: 0.9,\n      opacity: 0.8,\n      scrollTrigger: {\n        trigger: cards[index + 1],\n        start: \"top 60%\",\n        end: \"top 20%\",\n        scrub: true,\n      }\n    });\n  });\n\n  // Anime.js - 1. Text Scramble Hero Headline\n  const headlineEl = document.getElementById('hero-headline');\n  const originalText = \"Control total, territorio propio.\";\n  \n  animate(headlineEl, {\n    innerHTML: scrambleText({ \n      text: originalText, \n      chars: 'ABC012!@#$%&*?', \n      from: 'center', \n      revealRate: 50, \n      settleDuration: 600 \n    }),\n    duration: 2000,\n    ease: 'linear'\n  });\n\n  // Anime.js - 2. Sequential number/currency count-up\n  const countCurrency = () => {\n    document.querySelectorAll('.js-counter-currency').forEach(el => {\n      const target = parseFloat(el.dataset.value);\n      const state = { value: 0 };\n      animate(state, {\n        value: target,\n        duration: 1200,\n        delay: 500,\n        ease: 'out(3)',\n        onUpdate: () => {\n          el.textContent = state.value.toLocaleString('en-US', { \n            style: 'currency', \n            currency: 'USD',\n            minimumFractionDigits: target % 1 === 0 ? 0 : 2\n          });\n        }\n      });\n    });\n  };\n\n  const countNumbers = () => {\n    document.querySelectorAll('.js-counter-number').forEach(el => {\n      const target = parseFloat(el.dataset.value);\n      const suffix = el.dataset.suffix || '';\n      const prefix = el.dataset.prefix || '';\n      const format = el.dataset.format;\n      const state = { value: 0 };\n      \n      animate(state, {\n        value: target,\n        duration: 1500,\n        ease: 'out(4)',\n        onUpdate: () => {\n          let val = state.value;\n          if (format === 'short' && val >= 1000) {\n            el.textContent = prefix + (val / 1000).toFixed(0) + 'k' + suffix;\n          } else {\n            el.textContent = prefix + val.toFixed(target % 1 === 0 ? 0 : 1) + suffix;\n          }\n        }\n      });\n    });\n  };\n\n  // Bar chart fill\n  animate('.bar-fill', {\n    scaleY: [0, (el) => parseFloat(el.dataset.value) / 100],\n    transformOrigin: 'bottom',\n    delay: stagger(100),\n    duration: 800,\n    ease: 'out(3)'\n  });\n\n  // Scramble small stats\n  document.querySelectorAll('.js-scramble-small').forEach(el => {\n    animate(el, {\n      innerHTML: scrambleText({ \n        text: el.dataset.text, \n        chars: '0123456789/', \n        revealRate: 40 \n      }),\n      duration: 1000,\n      delay: 200\n    });\n  });\n\n  // Anime.js - 3. Grid-wave reveal via GSAP ScrollTrigger (for reliability)\n  const setupBentoReveal = () => {\n    gsap.set('.module-card', { opacity: 0, y: 30, scale: 0.98 });\n    \n    ScrollTrigger.create({\n      trigger: '#bento-container',\n      start: 'top 80%',\n      onEnter: () => {\n        animate('.module-card', {\n          opacity: [0, 1],\n          y: [30, 0],\n          scale: [0.98, 1],\n          delay: stagger(60, { grid: [12, 4], from: 'center' }),\n          duration: 600,\n          ease: 'out(4)'\n        });\n      }\n    });\n  };\n\n  // Reveal generic elements via ScrollTrigger for better reliability on deep sections\n  document.querySelectorAll('.js-reveal-up').forEach(el => {\n    gsap.set(el, { opacity: 0, y: 30 });\n    ScrollTrigger.create({\n      trigger: el,\n      start: 'top 90%',\n      onEnter: () => {\n        animate(el, {\n          opacity: [0, 1],\n          y: [30, 0],\n          duration: 600,\n          ease: 'out(3)'\n        });\n      }\n    });\n  });\n\n  animate('.js-reveal-scale', {\n    opacity: [0, 1],\n    scale: [0.9, 1],\n    duration: 1000,\n    ease: 'out(4)'\n  });\n\n  // Anime.js - 4. High-contrast 'color sweep' hover micro-interaction\n  const setupColorSweep = () => {\n    // Buttons\n    document.querySelectorAll('.color-sweep-btn').forEach(btn => {\n      const originalBg = '#003B46';\n      const hoverBg = '#0BDA51'; // Malachite from inspiration for precision feel\n\n      btn.addEventListener('pointerenter', () => {\n        animate(btn, { \n          backgroundColor: hoverBg, \n          color: '#000000',\n          scale: 1.02,\n          duration: 150, \n          ease: 'out(4)' \n        });\n      });\n      btn.addEventListener('pointerleave', () => {\n        animate(btn, { \n          backgroundColor: originalBg, \n          color: '#FFFFFF',\n          scale: 1,\n          duration: 250 \n        });\n      });\n    });\n\n    // Module Cards Sweep\n    document.querySelectorAll('.module-card').forEach(card => {\n      const isPrimary = card.classList.contains('bg-[#003B46]');\n      const isAccent = card.classList.contains('bg-[#66A5AD]');\n      \n      const originalBg = isPrimary ? '#003B46' : (isAccent ? '#66A5AD' : '#FFFFFF');\n      const originalTextColor = isPrimary || isAccent ? '#FFFFFF' : '#003B46';\n      \n      const hoverBg = isPrimary ? '#0BDA51' : (isAccent ? '#003B46' : '#003B46');\n      const hoverTextColor = isPrimary ? '#000000' : '#FFFFFF';\n\n      card.addEventListener('pointerenter', () => {\n        animate(card, { \n          backgroundColor: hoverBg, \n          color: hoverTextColor,\n          duration: 0, // Instant mechanical sweep\n          ease: 'linear'\n        });\n        const iconContainer = card.querySelector('.icon-container');\n        if (iconContainer) animate(iconContainer, { scale: 1.1, rotate: 5, duration: 200, ease: 'out(2)' });\n        const icon = card.querySelector('.icon-container i');\n        if (icon) animate(icon, { color: hoverTextColor, duration: 0 });\n      });\n      \n      card.addEventListener('pointerleave', () => {\n        animate(card, { \n          backgroundColor: originalBg, \n          color: originalTextColor,\n          duration: 150 \n        });\n        const icon = card.querySelector('.icon-container i');\n        if (icon) animate(icon, { color: isPrimary || isAccent ? '#FFFFFF' : (card.classList.contains('bg-white') ? (card.querySelector('.text-[#003B46]') ? '#003B46' : '#07575B') : '#FFFFFF'), duration: 150 });\n      });\n    });\n  };\n\n  // Run everything\n  countCurrency();\n  countNumbers();\n  setupBentoReveal();\n  setupColorSweep();\n\n  // Floating widgets movement (Anime version of the original GSAP one)\n  animate('.widget', {\n    y: [0, -20],\n    duration: 3000,\n    loop: true,\n    direction: 'alternate',\n    ease: 'inOutQuad',\n    delay: stagger(500)\n  });\n\n</script>\n",

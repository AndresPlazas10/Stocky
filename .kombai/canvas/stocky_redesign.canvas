      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap');\n\n  :root {\n    --color-bg: #E8F4F6;\n    --color-card: #FFFFFF;\n    --color-primary: #003B46;\n    --color-secondary: #07575B;\n    --color-accent: #66A5AD;\n    --font-sans: 'Plus Jakarta Sans', sans-serif;\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    background-color: var(--color-bg);\n    color: var(--color-primary);\n    font-family: var(--font-sans);\n    margin: 0;\n    overflow-x: clip;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .bento-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    grid-auto-rows: 240px;\n    gap: 1.5rem;\n  }\n\n  .card-shadow {\n    box-shadow: 12px 12px 0px rgba(0, 59, 70, 0.08);\n  }\n\n  .inset-strip {\n    box-shadow: inset 0 4px 12px rgba(0, 0, 0, 0.08);\n  }\n\n  .ticket-edge {\n    filter: drop-shadow(0 -10px 10px rgba(0,0,0,0.05));\n    mask-image: radial-gradient(circle at 10px -5px, transparent 10px, white 10.5px);\n    mask-size: 20px 100%;\n    mask-repeat: repeat-x;\n  }\n\n  .led-text {\n    font-family: var(--font-mono);\n    text-shadow: 0 0 10px rgba(7, 87, 91, 0.3);\n  }\n\n  .stacking-card {\n    position: sticky;\n    top: 15vh;\n  }\n\n  /* Refined radius for cleaner hierarchy */\n  .rounded-custom {\n    border-radius: 1.5rem; /* 24px */\n  }\n\n  /* Remove transitions from GSAP targets */\n  .gsap-no-trans {\n    transition: none !important;\n  }\n\n  .hero-mask-wrap {\n    clip-path: inset(0 100% 0 0);\n  }\n\n  /* Subtle structural pattern for hero */\n  .grid-bg {\n    background-image: radial-gradient(var(--color-accent) 0.5px, transparent 0.5px);\n    background-size: 24px 24px;\n    opacity: 0.15;\n  }\n\n  [data-lucide] {\n    display: inline-block;\n    vertical-align: middle;\n  }\n</style>\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n\n<nav class=\"fixed top-6 left-1/2 -translate-x-1/2 z-50 bg-white/80 backdrop-blur-xl px-8 py-4 rounded-full border border-teal-100 flex items-center gap-12 card-shadow\" data-kid=\"2\">\n  <div class=\"flex items-center gap-2\" data-kid=\"3\">\n    <div class=\"w-8 h-8 bg-[#003B46] rounded-lg flex items-center justify-center\" data-kid=\"4\">\n      <i data-lucide=\"package\" class=\"w-5 h-5 text-white\" data-kid=\"5\"></i>\n    </div>\n    <span class=\"font-bold text-xl tracking-tight\" data-kid=\"6\">Stocky</span>\n  </div>\n  <div class=\"hidden md:flex items-center gap-8 font-semibold text-sm\" data-kid=\"7\">\n    <a href=\"#process\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"8\">Proceso</a>\n    <a href=\"#modules\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"9\">Módulos</a>\n    <a href=\"#downloads\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"10\">Descargas</a>\n  </div>\n  <div class=\"flex items-center gap-4\" data-kid=\"11\">\n    <button class=\"px-6 py-2 rounded-full font-bold text-sm bg-[#003B46] text-white hover:bg-[#07575B] transition-all\" data-kid=\"12\">Empezar</button>\n  </div>\n</nav>\n\n<div class=\"hero-mask-wrap relative\" data-kid=\"13\">\n  <div class=\"absolute inset-0 grid-bg pointer-events-none\" data-kid=\"14\"></div>\n  <section class=\"relative min-h-screen pt-40 pb-20 flex flex-col items-center\" data-kid=\"15\">\n    <div class=\"max-w-4xl text-center px-6 mb-16 relative z-10 hero-text\" data-kid=\"16\">\n      <h1 class=\"text-6xl md:text-8xl font-extrabold tracking-tighter leading-tight mb-6 hero-reveal-item\" data-kid=\"17\">\n        Control total, <span class=\"text-[#66A5AD]\" data-kid=\"18\">territorio</span> propio.\n      </h1>\n      <p class=\"text-xl text-teal-900/80 max-w-2xl mx-auto font-medium leading-relaxed hero-reveal-item\" data-kid=\"19\">\n        El sistema POS diseñado como un ecosistema modular. Vende, gestiona y escala tu negocio con la precisión de un tablero de mando.\n      </p>\n    </div>\n\n    <div class=\"relative w-full max-w-6xl px-6 hero-media\" data-kid=\"20\">\n      <div class=\"widget absolute -top-12 -left-8 w-48 p-4 bg-white rounded-2xl card-shadow border border-teal-50 z-20\" data-kid=\"21\">\n        <div class=\"flex items-center justify-between mb-3\" data-kid=\"22\">\n          <div class=\"flex items-center gap-2\" data-kid=\"23\">\n            <div class=\"w-6 h-6 rounded bg-emerald-100 flex items-center justify-center\" data-kid=\"24\">\n              <i data-lucide=\"trending-up\" class=\"w-3 h-3 text-emerald-600\" data-kid=\"25\"></i>\n            </div>\n            <span class=\"text-[10px] font-bold opacity-40 uppercase\" data-kid=\"26\">Live Metrics</span>\n          </div>\n          <div class=\"flex items-center gap-1\" data-kid=\"27\">\n            <div class=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" data-kid=\"28\"></div>\n            <span class=\"text-[8px] font-bold text-emerald-600\" data-kid=\"29\">ONLINE</span>\n          </div>\n        </div>\n        <div class=\"text-2xl font-extrabold\" data-kid=\"30\">$2.450</div>\n        <div class=\"mt-2 h-8 w-full bg-emerald-50 rounded-md overflow-hidden flex items-end gap-1 px-1\" data-kid=\"31\">\n          <div class=\"w-full bg-emerald-300 rounded-t-sm\" style=\"height: 40%\" data-kid=\"32\"></div>\n          <div class=\"w-full bg-emerald-400 rounded-t-sm\" style=\"height: 60%\" data-kid=\"33\"></div>\n          <div class=\"w-full bg-emerald-500 rounded-t-sm\" style=\"height: 90%\" data-kid=\"34\"></div>\n          <div class=\"w-full bg-emerald-400 rounded-t-sm\" style=\"height: 70%\" data-kid=\"35\"></div>\n        </div>\n      </div>\n\n      <div class=\"widget absolute top-1/4 -right-12 w-56 p-4 bg-white rounded-2xl card-shadow border border-teal-50 z-20\" data-kid=\"36\">\n        <div class=\"flex items-center justify-between mb-4\" data-kid=\"37\">\n          <span class=\"text-xs font-bold opacity-40 uppercase\" data-kid=\"38\">Ticket Reciente</span>\n          <div class=\"w-2 h-2 rounded-full bg-orange-400 animate-pulse\" data-kid=\"39\"></div>\n        </div>\n        <div class=\"space-y-2\" data-kid=\"40\">\n          <div class=\"flex justify-between items-center text-sm font-bold\" data-kid=\"41\">\n            <span data-kid=\"42\">2x Burger Clásica</span>\n            <span data-kid=\"43\">$34.00</span>\n          </div>\n          <div class=\"flex justify-between items-center text-sm font-bold opacity-50\" data-kid=\"44\">\n            <span data-kid=\"45\">1x Soda Grande</span>\n            <span data-kid=\"46\">$4.50</span>\n          </div>\n          <hr class=\"border-teal-50\" data-kid=\"47\">\n          <div class=\"flex justify-between items-center text-lg font-extrabold\" data-kid=\"48\">\n            <span data-kid=\"49\">Total</span>\n            <span data-kid=\"50\">$38.50</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"relative w-full aspect-video bg-white p-4 rounded-[40px] card-shadow border border-teal-50 overflow-hidden\" data-kid=\"51\">\n        <video src=\"https://videos.pexels.com/video-files/6602061/6602061-sd_960_540_30fps.mp4\" poster=\"https://images.pexels.com/videos/6602061/pexels-photo-6602061.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover rounded-[32px]\" data-kid=\"52\"></video>\n        <div class=\"absolute inset-0 bg-gradient-to-t from-[#003B46]/20 to-transparent pointer-events-none\" data-kid=\"53\"></div>\n      </div>\n    </div>\n  </section>\n</div>\n\n<section class=\"py-16 bg-[#003B46]/5 border-y border-teal-100 overflow-hidden\" data-kid=\"54\">\n  <div class=\"max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 stats-container\" data-kid=\"55\">\n    <div class=\"stat-item section-reveal-item border-l-2 border-[#66A5AD] pl-6\" data-kid=\"56\">\n      <div class=\"led-text text-4xl md:text-5xl font-bold text-[#07575B] mb-2\" data-kid=\"57\"><span class=\"stat-number\" data-kid=\"58\">99.9</span>%</div>\n      <div class=\"text-[10px] font-bold uppercase tracking-widest text-[#66A5AD]\" data-kid=\"59\">Uptime Garantizado</div>\n    </div>\n    <div class=\"stat-item section-reveal-item border-l-2 border-[#66A5AD] pl-6\" data-kid=\"60\">\n      <div class=\"led-text text-4xl md:text-5xl font-bold text-[#07575B] mb-2\" data-kid=\"61\"><span class=\"stat-number\" data-kid=\"62\">0.4</span>s</div>\n      <div class=\"text-[10px] font-bold uppercase tracking-widest text-[#66A5AD]\" data-kid=\"63\">Latencia de Cobro</div>\n    </div>\n    <div class=\"stat-item section-reveal-item border-l-2 border-[#66A5AD] pl-6\" data-kid=\"64\">\n      <div class=\"led-text text-4xl md:text-5xl font-bold text-[#07575B] mb-2\" data-kid=\"65\">+<span class=\"stat-number\" data-kid=\"66\">12</span>k</div>\n      <div class=\"text-[10px] font-bold uppercase tracking-widest text-[#66A5AD]\" data-kid=\"67\">Ventas Diarias</div>\n    </div>\n    <div class=\"stat-item section-reveal-item border-l-2 border-[#66A5AD] pl-6\" data-kid=\"68\">\n      <div class=\"led-text text-4xl md:text-5xl font-bold text-[#07575B] mb-2\" data-kid=\"69\">24/7</div>\n      <div class=\"text-[10px] font-bold uppercase tracking-widest text-[#66A5AD]\" data-kid=\"70\">Soporte Local</div>\n    </div>\n  </div>\n</section>\n\n<section id=\"process\" class=\"py-32 bg-white\" data-kid=\"71\">\n  <div class=\"max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-20\" data-kid=\"72\">\n    <div class=\"md:sticky md:top-40 md:h-fit process-header\" data-kid=\"73\">\n      <h2 class=\"text-5xl font-extrabold tracking-tighter mb-8 leading-tight section-reveal-item\" data-kid=\"74\">\n        Tu operación,<br data-kid=\"75\"><span class=\"text-[#66A5AD]\" data-kid=\"76\">paso a paso.</span>\n      </h2>\n      <p class=\"text-lg text-teal-900/60 font-medium mb-12 section-reveal-item\" data-kid=\"77\">\n        Diseñamos el flujo de trabajo más eficiente del mercado. Sin fricción, sin complicaciones, solo resultados.\n      </p>\n      <div class=\"flex gap-4 section-reveal-item\" data-kid=\"78\">\n        <div class=\"w-12 h-1 bg-[#003B46] rounded-full\" data-kid=\"79\"></div>\n        <div class=\"w-12 h-1 bg-teal-100 rounded-full\" data-kid=\"80\"></div>\n        <div class=\"w-12 h-1 bg-teal-100 rounded-full\" data-kid=\"81\"></div>\n      </div>\n    </div>\n\n    <div class=\"space-y-24 process-cards\" data-kid=\"82\">\n      <div class=\"stacking-card p-10 bg-[#E8F4F6] rounded-3xl card-shadow border border-teal-100 gsap-no-trans\" data-kid=\"83\">\n        <div class=\"w-16 h-16 bg-white rounded-2xl flex items-center justify-center mb-8 shadow-sm\" data-kid=\"84\">\n          <i data-lucide=\"package\" class=\"w-10 h-10 text-[#003B46]\" data-kid=\"85\"></i>\n        </div>\n        <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"86\">01. Carga tu inventario</h3>\n        <p class=\"text-lg text-teal-900/80 font-medium leading-relaxed\" data-kid=\"87\">\n          Sube tus productos, variantes y precios en minutos. Sincronización inmediata con todas tus terminales.\n        </p>\n      </div>\n\n      <div class=\"stacking-card p-10 bg-[#66A5AD] text-white rounded-3xl card-shadow border border-teal-300 gsap-no-trans\" data-kid=\"88\">\n        <div class=\"w-16 h-16 bg-white/20 backdrop-blur rounded-2xl flex items-center justify-center mb-8\" data-kid=\"89\">\n          <i data-lucide=\"layout-dashboard\" class=\"w-10 h-10 text-white\" data-kid=\"90\"></i>\n        </div>\n        <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"91\">02. Vende & Controla</h3>\n        <p class=\"text-lg text-white/90 font-medium leading-relaxed\" data-kid=\"92\">\n          Interfaz optimizada para pantallas táctiles. Gestiona mesas, comandas y pagos con agilidad absoluta.\n        </p>\n      </div>\n\n      <div class=\"stacking-card p-10 bg-[#003B46] text-white rounded-3xl card-shadow border border-teal-900 overflow-hidden relative gsap-no-trans\" data-kid=\"93\">\n        <img src=\"https://images.unsplash.com/photo-1556740714-a8395b3bf30f?auto=format&w=800&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-10 grayscale pointer-events-none\" decoding=\"async\" loading=\"lazy\" data-kid=\"94\">\n        <div class=\"relative z-10\" data-kid=\"95\">\n          <div class=\"w-16 h-16 bg-white/10 backdrop-blur rounded-2xl flex items-center justify-center mb-8\" data-kid=\"96\">\n            <i data-lucide=\"line-chart\" class=\"w-10 h-10 text-[#66A5AD]\" data-kid=\"97\"></i>\n          </div>\n          <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"98\">03. Analiza & Crece</h3>\n          <p class=\"text-lg text-white/80 font-medium leading-relaxed\" data-kid=\"99\">\n            Reportes automáticos al cierre de turno. Descubre tus platos estrella y optimiza tus márgenes.\n          </p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section id=\"modules\" class=\"py-32 bg-[#E8F4F6]\" data-kid=\"100\">\n  <div class=\"max-w-7xl mx-auto px-6 text-center mb-20 modules-header\" data-kid=\"101\">\n    <span class=\"inline-block px-4 py-1 bg-white rounded-full text-xs font-bold uppercase tracking-widest text-[#003B46] mb-6 border border-teal-100 section-reveal-item\" data-kid=\"102\">Territorios Modulares</span>\n    <h2 class=\"text-5xl md:text-6xl font-extrabold tracking-tighter section-reveal-item\" data-kid=\"103\">Módulos que potencian <br data-kid=\"104\"> tu <span class=\"text-[#66A5AD]\" data-kid=\"105\">negocio.</span></h2>\n  </div>\n\n  <div class=\"max-w-7xl mx-auto px-6 bento-grid\" data-kid=\"106\">\n    <div class=\"col-span-2 row-span-1 bg-white p-10 rounded-3xl card-shadow border border-teal-100 flex items-center justify-between group overflow-hidden bento-item gsap-no-trans\" data-kid=\"107\">\n      <div class=\"max-w-[240px]\" data-kid=\"108\">\n        <h4 class=\"text-2xl font-bold mb-3\" data-kid=\"109\">Cobro Rápido</h4>\n        <p class=\"text-sm text-teal-900/80 font-medium\" data-kid=\"110\">Checkout en menos de 2 toques. Diseñado para entornos de alta rotación.</p>\n      </div>\n      <div class=\"relative\" data-kid=\"111\">\n        <div class=\"w-24 h-24 bg-[#E8F4F6] rounded-full flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"112\">\n          <i data-lucide=\"shopping-cart\" class=\"w-12 h-12 text-[#003B46]\" data-kid=\"113\"></i>\n        </div>\n        <div class=\"absolute -top-2 -right-2 bg-emerald-500 text-white text-[10px] font-bold px-2 py-1 rounded-full\" data-kid=\"114\">ACTIVE</div>\n      </div>\n    </div>\n\n    <div class=\"col-span-1 row-span-1 bg-white p-8 rounded-3xl card-shadow border border-teal-50 flex flex-col justify-between group bento-item gsap-no-trans\" data-kid=\"115\">\n      <div class=\"w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center mb-4 group-hover:rotate-12 transition-transform\" data-kid=\"116\">\n        <i data-lucide=\"receipt\" class=\"w-6 h-6 text-[#07575B]\" data-kid=\"117\"></i>\n      </div>\n      <div data-kid=\"118\">\n        <h4 class=\"text-xl font-bold mb-2\" data-kid=\"119\">Facturación</h4>\n        <p class=\"text-sm text-teal-900/80 font-medium\" data-kid=\"120\">Electrónica y simplificada. 100% legal.</p>\n      </div>\n    </div>\n\n    <div class=\"col-span-1 row-span-1 bg-[#003B46] p-8 rounded-3xl card-shadow border border-teal-900 text-white group bento-item gsap-no-trans\" data-kid=\"121\">\n      <div class=\"w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center mb-4\" data-kid=\"122\">\n        <i data-lucide=\"bar-chart-3\" class=\"w-6 h-6 text-[#66A5AD]\" data-kid=\"123\"></i>\n      </div>\n      <h4 class=\"text-xl font-bold mb-2\" data-kid=\"124\">Reportes</h4>\n      <p class=\"text-sm text-white/60 font-medium\" data-kid=\"125\">Métricas claras en tiempo real. Exporta en un click.</p>\n    </div>\n\n    <div class=\"col-span-1 row-span-1 bg-white p-8 rounded-3xl card-shadow border border-teal-50 group bento-item gsap-no-trans\" data-kid=\"126\">\n      <div class=\"w-12 h-12 bg-[#E8F4F6] rounded-xl flex items-center justify-center mb-4\" data-kid=\"127\">\n        <i data-lucide=\"users\" class=\"w-6 h-6 text-[#003B46]\" data-kid=\"128\"></i>\n      </div>\n      <h4 class=\"text-xl font-bold mb-2\" data-kid=\"129\">Empleados</h4>\n      <p class=\"text-sm text-teal-900/80 font-medium\" data-kid=\"130\">Roles y permisos definidos. Control de turnos.</p>\n    </div>\n\n    <div class=\"col-span-2 row-span-1 bg-white p-10 rounded-3xl card-shadow border border-teal-50 flex gap-8 items-center overflow-hidden bento-item gsap-no-trans\" data-kid=\"131\">\n      <div class=\"flex-1\" data-kid=\"132\">\n        <h4 class=\"text-2xl font-bold mb-3\" data-kid=\"133\">Información Segura</h4>\n        <p class=\"text-sm text-teal-900/80 font-medium\" data-kid=\"134\">Encriptación de grado bancario para todos tus datos sensibles y transacciones.</p>\n      </div>\n      <div class=\"w-32 h-32 bg-teal-50 rounded-3xl flex items-center justify-center border-2 border-dashed border-teal-100\" data-kid=\"135\">\n        <i data-lucide=\"shield-check\" class=\"w-16 h-16 text-[#66A5AD]\" data-kid=\"136\"></i>\n      </div>\n    </div>\n\n    <div class=\"col-span-1 row-span-1 bg-[#66A5AD] p-8 rounded-3xl card-shadow border border-teal-300 text-white group bento-item gsap-no-trans\" data-kid=\"137\">\n      <div class=\"w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mb-4\" data-kid=\"138\">\n        <i data-lucide=\"clock\" class=\"w-6 h-6 text-white\" data-kid=\"139\"></i>\n      </div>\n      <h4 class=\"text-xl font-bold mb-2\" data-kid=\"140\">Cierre Fácil</h4>\n      <p class=\"text-sm text-white/80 font-medium\" data-kid=\"141\">Cuadre de caja automático al final del día. Sin errores.</p>\n    </div>\n  </div>\n</section>\n\n<section id=\"start\" class=\"py-40 bg-[#003B46] relative overflow-hidden flex items-center justify-center\" data-kid=\"142\">\n  <div class=\"absolute inset-0 opacity-10\" data-kid=\"143\">\n    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checked-shield.svg\" class=\"absolute -top-20 -left-20 w-80 h-80 text-teal-100\" data-kid=\"144\">\n    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checked-shield.svg\" class=\"absolute -bottom-20 -right-20 w-80 h-80 text-teal-100\" data-kid=\"145\">\n  </div>\n\n  <div class=\"relative z-10 w-full max-w-2xl px-6\" data-kid=\"146\">\n    <div class=\"bg-white p-16 rounded-t-[40px] rounded-b-[40px] ticket-edge card-shadow relative final-ticket\" data-kid=\"147\">\n      <div class=\"absolute -top-6 left-0 w-full h-12 bg-white flex items-center justify-around px-4 pointer-events-none\" data-kid=\"148\">\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"149\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"150\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"151\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"152\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"153\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"154\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"155\"></div>\n        <div class=\"w-3 h-6 bg-[#003B46] rounded-full\" data-kid=\"156\"></div>\n      </div>\n\n      <div class=\"text-center\" data-kid=\"157\">\n        <span class=\"text-xs font-bold uppercase tracking-widest text-[#66A5AD] mb-4 block\" data-kid=\"158\">ORDEN #2026-STOCKY</span>\n        <h2 class=\"text-5xl font-extrabold tracking-tighter mb-8 leading-tight\" data-kid=\"159\">¿Listo para <br data-kid=\"160\"> <span class=\"text-[#07575B]\" data-kid=\"161\">abrir?</span></h2>\n        <p class=\"text-lg text-teal-900/60 font-medium mb-12\" data-kid=\"162\">\n          Únete a los más de 500 establecimientos que ya optimizan su operación con StockyPOS.\n        </p>\n\n        <div class=\"flex justify-center gap-1 mb-12 h-12 items-center opacity-30\" data-kid=\"163\">\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"164\"></div>\n          <div class=\"w-2 h-full bg-[#003B46]\" data-kid=\"165\"></div>\n          <div class=\"w-0.5 h-full bg-[#003B46]\" data-kid=\"166\"></div>\n          <div class=\"w-3 h-full bg-[#003B46]\" data-kid=\"167\"></div>\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"168\"></div>\n          <div class=\"w-4 h-full bg-[#003B46]\" data-kid=\"169\"></div>\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"170\"></div>\n          <div class=\"w-2 h-full bg-[#003B46]\" data-kid=\"171\"></div>\n          <div class=\"w-1 h-full bg-[#003B46]\" data-kid=\"172\"></div>\n          <div class=\"w-3 h-full bg-[#003B46]\" data-kid=\"173\"></div>\n          <div class=\"w-0.5 h-full bg-[#003B46]\" data-kid=\"174\"></div>\n          <div class=\"w-2 h-full bg-[#003B46]\" data-kid=\"175\"></div>\n        </div>\n\n        <div class=\"flex flex-col sm:flex-row gap-4 justify-center\" data-kid=\"176\">\n          <button class=\"px-12 py-5 bg-[#003B46] text-white rounded-2xl font-bold text-lg hover:scale-105 transition-transform card-shadow\" data-kid=\"177\">Empieza Gratis</button>\n          <button class=\"px-12 py-5 border-2 border-[#003B46] text-[#003B46] rounded-2xl font-bold text-lg hover:bg-teal-50 transition-all\" data-kid=\"178\">Ver Demo</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<footer class=\"py-20 bg-white border-t border-teal-50\" data-kid=\"179\">\n  <div class=\"max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"180\">\n    <div class=\"col-span-2\" data-kid=\"181\">\n      <div class=\"flex items-center gap-2 mb-6\" data-kid=\"182\">\n        <div class=\"w-10 h-10 bg-[#003B46] rounded-xl flex items-center justify-center\" data-kid=\"183\">\n          <i data-lucide=\"package\" class=\"w-6 h-6 text-white\" data-kid=\"184\"></i>\n        </div>\n        <span class=\"font-extrabold text-2xl tracking-tighter\" data-kid=\"185\">Stocky</span>\n      </div>\n      <p class=\"text-teal-900/50 max-w-sm font-medium leading-relaxed\" data-kid=\"186\">\n        El ecosistema digital definitivo para la industria gastronómica. Nacido en Medellín, diseñado para el mundo.\n      </p>\n    </div>\n    \n    <div class=\"text-center md:text-left\" data-kid=\"187\">\n      <h5 class=\"font-bold text-sm uppercase tracking-widest text-[#66A5AD] mb-6\" data-kid=\"188\">Legal</h5>\n      <ul class=\"space-y-4 text-sm font-semibold\" data-kid=\"189\">\n        <li data-kid=\"190\"><a href=\"#\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"191\">Privacidad</a></li>\n        <li data-kid=\"192\"><a href=\"#\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"193\">Términos</a></li>\n        <li data-kid=\"194\"><a href=\"#\" class=\"hover:text-[#66A5AD] transition-colors\" data-kid=\"195\">Cookies</a></li>\n      </ul>\n    </div>\n    \n    <div class=\"flex flex-col items-center md:items-end justify-start\" data-kid=\"196\">\n      <h5 class=\"font-bold text-sm uppercase tracking-widest text-[#66A5AD] mb-6 invisible\" data-kid=\"197\">Social</h5>\n      <div class=\"flex gap-6 text-[#003B46]\" data-kid=\"198\">\n        <i data-lucide=\"instagram\" class=\"w-5 h-5 cursor-pointer hover:text-[#66A5AD]\" data-kid=\"199\"></i>\n        <i data-lucide=\"twitter\" class=\"w-5 h-5 cursor-pointer hover:text-[#66A5AD]\" data-kid=\"200\"></i>\n        <i data-lucide=\"linkedin\" class=\"w-5 h-5 cursor-pointer hover:text-[#66A5AD]\" data-kid=\"201\"></i>\n      </div>\n    </div>\n  </div>\n  <div class=\"max-w-7xl mx-auto px-6 mt-20 pt-8 border-t border-teal-50 flex flex-col md:flex-row justify-between items-center gap-4\" data-kid=\"202\">\n    <p class=\"text-xs font-bold text-teal-900/30\" data-kid=\"203\">© 2026 STOCKY POS. TODOS LOS DERECHOS RESERVADOS.</p>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"204\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"205\"></script>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"206\"></script>\n<script type=\"module\" data-kid=\"207\">\n  import Lenis from \"https://esm.sh/lenis@1\";\n  import Snap from \"https://esm.sh/lenis@1/snap\";\n  \n  // Initialize Lenis without autoRaf for GSAP sync\n  const lenis = new Lenis();\n\n  lenis.on('scroll', ScrollTrigger.update);\n\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n\n  gsap.ticker.lagSmoothing(0);\n\n  function initIcons() {\n    if (typeof lucide !== 'undefined') {\n      lucide.createIcons();\n    } else {\n      setTimeout(initIcons, 50);\n    }\n  }\n  initIcons();\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // 1. Mask-wipe reveal for the hero section entrance\n  gsap.fromTo(\".hero-mask-wrap\", \n    { clipPath: \"inset(0 100% 0 0)\" }, \n    { clipPath: \"inset(0 0 0 0)\", duration: 1.2, ease: \"power3.inOut\" }\n  );\n\n  // Entrance reveal for hero text & media\n  gsap.from(\".hero-reveal-item\", {\n    y: 50,\n    autoAlpha: 0,\n    duration: 1,\n    stagger: 0.2,\n    ease: \"power4.out\",\n    delay: 0.5\n  });\n\n  gsap.from(\".hero-media\", {\n    scale: 0.9,\n    autoAlpha: 0,\n    duration: 1.5,\n    ease: \"expo.out\",\n    delay: 0.8\n  });\n\n  // 2. Yoyo-pulse animation for floating widgets\n  gsap.to(\".widget\", {\n    y: -30,\n    scale: 1.05,\n    duration: 1.8,\n    repeat: -1,\n    yoyo: true,\n    ease: \"power2.in\",\n    yoyoEase: \"power2.out\",\n    stagger: {\n      amount: 0.6,\n      from: \"random\"\n    }\n  });\n\n  // 3. Refine the sticky stack effect in the process section with smooth scaling\n  const cards = gsap.utils.toArray(\".stacking-card\");\n  cards.forEach((card, index) => {\n    if (index === cards.length - 1) return;\n    \n    gsap.to(card, {\n      scale: 0.85,\n      opacity: 0.5,\n      filter: \"blur(4px)\",\n      yPercent: -10,\n      scrollTrigger: {\n        trigger: cards[index + 1],\n        start: \"top 70%\",\n        end: \"top 20%\",\n        scrub: true,\n      }\n    });\n  });\n\n  // 4. Staggered blur-in reveals for Bento grid modules\n  gsap.from(\".bento-item\", {\n    autoAlpha: 0,\n    filter: \"blur(15px)\",\n    y: 60,\n    duration: 1.2,\n    stagger: 0.15,\n    ease: \"power3.out\",\n    scrollTrigger: {\n      trigger: \".bento-grid\",\n      start: \"top 85%\",\n      toggleActions: \"play none none none\"\n    }\n  });\n\n  // Varied entrance animations\n  gsap.from(\".stat-item\", {\n    x: -30,\n    autoAlpha: 0,\n    duration: 0.8,\n    stagger: 0.1,\n    ease: \"power3.out\",\n    scrollTrigger: {\n      trigger: \".stats-container\",\n      start: \"top 90%\",\n    }\n  });\n\n  // Numeric count up\n  document.querySelectorAll('.stat-number').forEach(el => {\n    const endVal = parseFloat(el.textContent);\n    gsap.fromTo(el, { textContent: 0 }, {\n      textContent: endVal,\n      duration: 2.5,\n      ease: \"power2.out\",\n      scrollTrigger: {\n        trigger: \".stats-container\",\n        start: \"top 90%\",\n      },\n      onUpdate: function() {\n        if (el.textContent.includes('.')) {\n          el.textContent = parseFloat(this.targets()[0].textContent).toFixed(1);\n        } else {\n          el.textContent = Math.ceil(this.targets()[0].textContent);\n        }\n      }\n    });\n  });\n\n  gsap.from(\".modules-header .section-reveal-item\", {\n    y: 30,\n    autoAlpha: 0,\n    filter: \"blur(8px)\",\n    duration: 1,\n    stagger: 0.2,\n    ease: \"power2.out\",\n    scrollTrigger: {\n      trigger: \".modules-header\",\n      start: \"top 85%\",\n    }\n  });\n\n  // Final ticket entrance\n  gsap.from(\".final-ticket\", {\n    y: 100,\n    autoAlpha: 0,\n    rotateX: -15,\n    duration: 1.4,\n    ease: \"expo.out\",\n    scrollTrigger: {\n      trigger: \"#start\",\n      start: \"top 80%\",\n    }\n  });\n</script>\n",

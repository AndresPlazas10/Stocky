# ==================================================
# Stocky - Environment template (safe placeholders)
# ==================================================
# Copy to .env.local for local development:
#   cp .env.example .env.local

# --------------------------------------------------
# Required: Supabase client
# --------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional server-side key (NEVER expose in client code)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional app URL (used by some links/flows)
VITE_APP_URL=http://localhost:5173

# --------------------------------------------------
# Email providers
# --------------------------------------------------
# Provider hint: auto | emailjs | resend
VITE_EMAIL_PROVIDER=auto
# En producción se recomienda mantener solo Resend para evitar remitentes no corporativos.
VITE_ENFORCE_RESEND_ONLY=true

# EmailJS
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# Resend (cliente: solo señalización/UX, sin secretos)
VITE_RESEND_FROM_EMAIL=soporte@stockypos.app
# Legacy fallback key name used in some config paths
VITE_FROM_EMAIL=soporte@stockypos.app
VITE_RESEND_ENABLED=true

# Resend (server-only, configurar en Vercel/Supabase Functions)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Stocky <soporte@stockypos.app>

# Redirect outbound emails in local dev/testing
VITE_TEST_EMAIL=dev@example.com

# --------------------------------------------------
# Local-first sync (deprecated - online-only rollback)
# --------------------------------------------------
VITE_LOCAL_SYNC_ENABLED=false
VITE_LOCAL_SYNC_DEVTOOLS=false
VITE_LOCAL_SYNC_PREFER_PGLITE=false
VITE_LOCAL_SYNC_SHADOW_WRITES=false
VITE_LOCAL_SYNC_VERIFY_REMOTE=false
VITE_LOCAL_SYNC_OUTBOX_POLL_MS=4000
VITE_LOCAL_SYNC_OUTBOX_BATCH_SIZE=20
VITE_LOCAL_SYNC_OUTBOX_MAX_EVENTS_PER_TICK=200
VITE_LOCAL_SYNC_OUTBOX_MAX_RETRIES=5
VITE_LOCAL_SYNC_OUTBOX_RATE_WINDOW_SIZE=100
VITE_LOCAL_SYNC_OUTBOX_RATE_WINDOW_MINUTES=15
VITE_ELECTRIC_PULL_ENABLED=false
VITE_LOCAL_SYNC_READ_CACHE_TTL_MS=30000

# Local write flags
VITE_FF_LOCAL_WRITE_SALES=false
VITE_FF_LOCAL_FIRST_SALES=false
VITE_FF_LOCAL_WRITE_PURCHASES=false
VITE_FF_LOCAL_FIRST_PURCHASES=false
VITE_FF_LOCAL_WRITE_ORDERS=false
VITE_FF_LOCAL_FIRST_ORDERS=false
VITE_FF_LOCAL_WRITE_TABLES=false
VITE_FF_LOCAL_FIRST_TABLES=false
VITE_FF_LOCAL_FIRST_ALL=false
VITE_FF_LOCAL_WRITE_PRODUCTS=false
VITE_FF_LOCAL_FIRST_PRODUCTS=false
VITE_FF_LOCAL_WRITE_SUPPLIERS=false
VITE_FF_LOCAL_FIRST_SUPPLIERS=false
VITE_FF_LOCAL_WRITE_INVOICES=false
VITE_FF_LOCAL_FIRST_INVOICES=false

# Local read flags
VITE_FF_LOCAL_READ_PRODUCTS=false
VITE_FF_LOCAL_READ_SALES=false
VITE_FF_LOCAL_READ_PURCHASES=false
VITE_FF_LOCAL_READ_ORDERS=false
VITE_FF_LOCAL_READ_INVENTORY=false
VITE_FF_LOCAL_READ_INVOICES=false

# --------------------------------------------------
# Security notes
# --------------------------------------------------
# - Do not commit .env.local
# - Do not put real secrets in .env.example
# - Keep service role keys only in trusted server environments

# --------------------------------------------------
# Realtime audit (staging)
# --------------------------------------------------
REALTIME_TEST_BUSINESS_ID=00000000-0000-0000-0000-000000000000
REALTIME_OWNER_EMAIL=owner@example.com
REALTIME_OWNER_PASSWORD=owner_password
REALTIME_EMPLOYEE_EMAIL=employee@example.com
REALTIME_EMPLOYEE_PASSWORD=employee_password
REALTIME_OUTSIDER_EMAIL=outsider@example.com
REALTIME_OUTSIDER_PASSWORD=outsider_password

# DB contract check via psql (recommended for audit:realtime:db)
SUPABASE_DB_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres

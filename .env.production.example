# ============================================
# 🚀 VARIABLES DE ENTORNO - PRODUCCIÓN
# ============================================
# Este archivo es un ejemplo de las variables necesarias para Vercel
# NO incluir valores reales aquí (usar Vercel Dashboard)

# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# URL de la aplicación
VITE_APP_URL=https://tu-app.vercel.app
VITE_ENFORCE_RESEND_ONLY=true

# Resend (Email transaccional - RECOMENDADO)
VITE_RESEND_API_KEY=re_tu_api_key_aqui
VITE_RESEND_FROM_EMAIL=soporte@stockypos.app
RESEND_API_KEY=re_tu_api_key_aqui
RESEND_FROM_EMAIL=Stocky <soporte@stockypos.app>

# EmailJS (Fallback - opcional)
VITE_EMAILJS_PUBLIC_KEY=tu_public_key
VITE_EMAILJS_SERVICE_ID=tu_service_id
VITE_EMAILJS_TEMPLATE_ID=tu_template_id

# ⚠️ IMPORTANTE:
# - NO incluir VITE_TEST_EMAIL en producción
# - Configurar estas variables en Vercel Dashboard → Settings → Environment Variables
# - Marcar como "Production" y "Preview" según necesites
# - Redesplegar después de agregar/modificar variables

# Local Sync / hardening producción
# Mantener desactivadas herramientas de depuración en navegador.
VITE_LOCAL_SYNC_DEVTOOLS=false

# Recomendación Realtime estable:
# Mantener desactivado local-first forzado para que los cambios
# se escriban primero en remoto y se propaguen por Realtime.
VITE_FF_LOCAL_FIRST_ALL=false
VITE_FF_LOCAL_FIRST_ORDERS=false
VITE_FF_LOCAL_FIRST_TABLES=false
VITE_FF_LOCAL_FIRST_SALES=false
VITE_FF_LOCAL_FIRST_PURCHASES=false
VITE_FF_LOCAL_FIRST_PRODUCTS=false
VITE_FF_LOCAL_FIRST_SUPPLIERS=false
VITE_FF_LOCAL_FIRST_INVOICES=false

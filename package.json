{
  "name": "stocky",
  "version": "1.0.0",
  "description": "Sistema POS completo con facturación electrónica, gestión de inventario y ventas",
  "author": "Andres Plazas",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/mobile"
  ],
  "keywords": [
    "pos",
    "punto-de-venta",
    "facturacion",
    "inventario",
    "ventas",
    "supabase",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AndresPlazas10/Stocky"
  },
  "bugs": {
    "url": "https://github.com/AndresPlazas10/Stocky/issues"
  },
  "homepage": "https://github.com/AndresPlazas10/Stocky#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test testing/*.test.js",
    "test:offline": "node --import tsx --test testing/closeOrderLocks.test.js testing/localOutboxEventsStore.test.js testing/offlineStockGuards.test.js testing/outboxMutationHandlers.test.js testing/outboxProcessorLocal.test.js testing/salesOutboxDedup.test.js testing/salesSnapshotSync.test.js testing/salesOutboxCandidates.test.js testing/salesOutboxRetryPolicy.test.js testing/salesOutboxTransitions.test.js",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preview": "vite preview",
    "clean": "rm -rf dist node_modules",
    "reinstall": "npm run clean && npm install",
    "analyze": "vite build --mode analyze",
    "audit:realtime:map": "node scripts/realtime-audit/generate-realtime-map.mjs",
    "audit:realtime:db": "node scripts/realtime-audit/run-db-contract-check.mjs",
    "audit:realtime:smoke": "node scripts/realtime-audit/run-realtime-smoke.mjs",
    "audit:realtime:filters": "node scripts/security/realtime_filter_audit.mjs",
    "audit:realtime:report": "node scripts/realtime-audit/build-audit-report.mjs",
    "audit:realtime": "node scripts/realtime-audit/run-all.mjs",
    "audit:security": "npm audit --audit-level=critical && (cd apps/mobile && npm audit --audit-level=critical)",
    "audit:perf:baseline": "node scripts/perf/run-week1-baseline.mjs",
    "audit:perf:csv-summary": "node scripts/perf/summarize-baseline-csv.mjs",
    "audit:perf:budget": "node scripts/perf/check-week1-budget.mjs",
    "audit:perf:pr-diff": "node scripts/perf/build-pr-budget-diff.mjs",
    "audit:perf:ci": "node scripts/perf/run-week1-baseline.mjs --out-json testing/perf/perf-current.json --out-md docs/perf/PERF_CURRENT.md && node scripts/perf/check-week1-budget.mjs --current testing/perf/perf-current.json --budget testing/perf/perf-budget.json",
    "check": "npm run lint && npm run build",
    "predeploy": "npm run lint && npm run test && npm run test:offline && npm run build",
    "check:production": "./check-production.sh",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:web": "npm --prefix apps/mobile run web"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@sentry/react": "^10.52.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.97",
    "@stocky/shared": "workspace:*",
    "@supabase/supabase-js": "^2.80.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "gsap": "^3.15.0",
    "lucide-react": "^0.553.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.5",
    "tailwind-merge": "^3.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "express": "^5.2.1",
    "globals": "^16.4.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vercel": "^50.9.6",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
